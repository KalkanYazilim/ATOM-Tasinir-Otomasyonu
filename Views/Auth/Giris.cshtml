@{
    Layout = null;
    ViewData["Title"] = "Giriş";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>ATOM – Giriş</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
    <style>
        body { background: linear-gradient(135deg, #1a3a6b 0%, #2d6a9f 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; }
        .login-card { background: #fff; border-radius: 1rem; padding: 2.5rem; width: 100%; max-width: 420px; box-shadow: 0 10px 40px rgba(0,0,0,.25); }
        .logo-area { text-align: center; margin-bottom: 2rem; }
        .logo-area .logo-text { font-size: 2.2rem; font-weight: 800; letter-spacing: 4px; color: #1a3a6b; }
        .logo-area .logo-sub { font-size: .78rem; color: #666; letter-spacing: 1px; }
    </style>
</head>
<body>
<div class="login-card">
    <div class="logo-area">
        <div class="logo-text"><i class="bi bi-box-seam me-2"></i>ATOM</div>
        <div class="logo-sub">TAŞINIR MALZEME OTOMASYONU</div>
        <hr/>
        <small class="text-muted">Lütfen kimlik bilgilerinizle giriş yapın.</small>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger py-2">
            @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <div>@err.ErrorMessage</div>
            }
        </div>
    }

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]"/>
        <div class="mb-3">
            <label class="form-label fw-semibold">Kullanıcı Adı</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input type="text" name="kullaniciAdi" class="form-control" required autofocus placeholder="kullanici_adi"/>
            </div>
        </div>
        <div class="mb-4">
            <label class="form-label fw-semibold">Şifre</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                <input type="password" name="sifre" class="form-control" required placeholder="••••••••"/>
            </div>
        </div>
        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
            <i class="bi bi-box-arrow-in-right me-2"></i>Giriş Yap
        </button>
    </form>

    <div class="mt-4 p-3 bg-light rounded">
        <small class="text-muted"><strong>Demo Hesaplar:</strong><br/>
        admin / Admin123! – Sistem Yöneticisi<br/>
        merkez / Merkez123! – Bakanlık Merkez<br/>
        satinalma / Satin123! – Satın Alma<br/>
        ankara / Ankara123! – Ankara İl Müdürü<br/>
        tedarikci1 / Firma123! – Tedarikçi</small>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
