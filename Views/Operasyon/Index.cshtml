@section Scripts {
<script src="~/lib/leaflet/leaflet.js" asp-append-version="true"></script>
<script>
let sur = null;
const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
const depoHaritaVerisi = @Html.Raw(depoHaritaJson);
const depoStorageKey = 'atom.operasyon.sonDepolar.@kullaniciAnahtari';
let atomDepotMap = null;
let atomProvinceLayer = null;
const atomDepotMarkers = new Map();
const atomDepotMarkerItems = [];

function sonDepolariOku() {
    try {
        const value = JSON.parse(localStorage.getItem(depoStorageKey) || '[]');
        return Array.isArray(value) ? value.filter(Boolean) : [];
    } catch {
        return [];
    }
}

function sonDepolariYaz(depoIds) {
    const temiz = [];
    depoIds.forEach(id => {
        if (id && !temiz.includes(id)) temiz.push(id);
    });
    localStorage.setItem(depoStorageKey, JSON.stringify(temiz.slice(0, 12)));
}

function sonDepoyaEkle(...depoIds) {
    const mevcut = sonDepolariOku().filter(id => !depoIds.includes(id));
    sonDepolariYaz([...depoIds.filter(Boolean), ...mevcut]);
}

function sonDepodanCikar(depoId) {
    sonDepolariYaz(sonDepolariOku().filter(id => id !== depoId));
}

function varsayilanDepolariAc() {
    const sonDepolar = sonDepolariOku();
    sonDepolar.forEach(depoId => depoGoster(depoId, { scroll: false, focusMap: false, remember: false }));
    operasyonCalismaAlaniGuncelle();
}

function operasyonCalismaAlaniGuncelle() {
    const workspace = document.getElementById('operationWorkspace');
    if (!workspace) return;
    const acikDepolar = Array.from(document.querySelectorAll('[data-depo-card]')).filter(x => !x.classList.contains('is-hidden'));
    const acikDepoVar = acikDepolar.length > 0;
    workspace.classList.toggle('is-empty', !acikDepoVar);
    const acikDepoIds = new Set(acikDepolar.map(x => x.dataset.depoCard));
    document.querySelectorAll('[data-personel-depo-group]').forEach(group => {
        group.classList.toggle('is-hidden', acikDepoVar && !acikDepoIds.has(group.dataset.personelDepoGroup));
    });
    document.querySelectorAll('.personel-baglantisiz').forEach(card => {
        card.classList.toggle('is-hidden', acikDepoVar);
    });
}

function atomNormalize(value) {
    return (value || '').toLocaleLowerCase('tr-TR')
        .replaceAll('ı', 'i').replaceAll('ğ', 'g').replaceAll('ü', 'u')
        .replaceAll('ş', 's').replaceAll('ö', 'o').replaceAll('ç', 'c')
        .replace(/\s+/g, ' ').trim();
}

function atomProvinceMatches(provinceName, depotCity) {
    const province = atomNormalize(provinceName);
    const city = atomNormalize(depotCity);
    return province === city || province.startsWith(city) || city.startsWith(province);
}

function atomProvinceStyle(feature) {
    const city = feature?.properties?.name || '';
    const hasDepot = depoHaritaVerisi.some(depo => atomProvinceMatches(city, depo.il));
    return {
        color: hasDepot ? '#1a3a6b' : '#8aa0b6',
        fillColor: hasDepot ? '#dceafe' : '#edf3f8',
        fillOpacity: hasDepot ? .34 : .13,
        opacity: .9,
        weight: hasDepot ? 1.8 : 1
    };
}

function atomCreateDepotIcon(depo) {
    const html = `<span class="atom-map-depo-marker" data-depo-id="${depo.id}" style="--depo-color:${depo.color}">
        <i class="bi ${depo.icon}"></i><b>${depo.toplam}</b>
    </span>`;
    return L.divIcon({ className: 'atom-depot-div-icon', html, iconSize: [38, 38], iconAnchor: [19, 19] });
}

function atomDepotTooltip(depo) {
    return `<div class="atom-map-tooltip">
        <strong>${depo.ad}</strong>
        <div>İl: ${depo.il}</div>
        <div>Adres: ${depo.adres || '-'}</div>
        <div>Toplam stok: <span class="text-primary fw-semibold">${depo.toplam}</span></div>
        <div>Sarf çeşit: ${depo.sarf} · Demirbaş: ${depo.demirbas}</div>
    </div>`;
}

function atomDepotMarkerVisible(item) {
    if (!atomDepotMap) return false;
    const zoom = atomDepotMap.getZoom();
    if (item.depo.level === 'merkez') return true;
    if (item.depo.level === 'il') return zoom >= 6.8;
    if (zoom < 8.4) return false;
    return atomDepotMap.getBounds().pad(.35).contains(item.marker.getLatLng());
}

function atomMarkerGorunumunuGuncelle() {
    if (!atomDepotMap) return;
    atomDepotMarkerItems.forEach(item => {
        const visible = atomDepotMarkerVisible(item);
        const onMap = atomDepotMap.hasLayer(item.marker);
        if (visible && !onMap) item.marker.addTo(atomDepotMap);
        if (!visible && onMap) atomDepotMap.removeLayer(item.marker);
    });
}

function atomAttachMarkerDrop(marker, depo) {
    marker.on('add', () => {
        const el = marker.getElement();
        const target = el?.querySelector('.atom-map-depo-marker');
        if (!target) return;
        target.addEventListener('dragover', event => {
            event.preventDefault();
            target.classList.add('is-drop-target');
        });
        target.addEventListener('dragleave', () => target.classList.remove('is-drop-target'));
        target.addEventListener('drop', event => {
            target.classList.remove('is-drop-target');
            depoyaBirak(event, depo.id, depo.ad);
        });
    });
}

async function atomHaritayiBaslat() {
    const mapEl = document.getElementById('atomDepotMap');
    if (!mapEl || !window.L) return;
    atomDepotMap = L.map(mapEl, { zoomControl: true, preferCanvas: true, minZoom: 5, maxBoundsViscosity: .35 })
        .setView([39, 35], 6);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 18,
        attribution: '&copy; OpenStreetMap katkıcıları'
    }).addTo(atomDepotMap);

    const response = await fetch('/data/maps/turkey-provinces.json', { headers: { 'Accept': 'application/json' } });
    if (!response.ok) throw new Error('Türkiye il sınırları yüklenemedi.');
    const provinces = await response.json();
    const provinceCenters = new Map();

    atomProvinceLayer = L.geoJSON(provinces, {
        style: atomProvinceStyle,
        onEachFeature: (feature, layer) => {
            const props = feature.properties || {};
            const city = props.name || '';
            if (layer.getBounds?.().isValid()) {
                provinceCenters.set(atomNormalize(city), layer.getBounds().getCenter());
            }
            layer.bindTooltip(`<strong>${city}</strong>`, { sticky: true, direction: 'top' });
            layer.on('mouseover', () => layer.setStyle({ fillOpacity: .46, weight: 2.6 }));
            layer.on('mouseout', () => layer.setStyle(atomProvinceStyle(feature)));
            layer.on('click', () => {
                const matched = depoHaritaVerisi.filter(depo => atomProvinceMatches(city, depo.il));
                if (matched.length) {
                    matched.forEach(depo => depoGoster(depo.id, { focusMap: false }));
                    atomDepotMap.fitBounds(layer.getBounds(), { padding: [28, 28], maxZoom: 9 });
                }
            });
        }
    }).addTo(atomDepotMap);

    depoHaritaVerisi.forEach((depo, index) => {
        const exact = provinceCenters.get(atomNormalize(depo.il));
        const fallback = Array.from(provinceCenters.entries()).find(([name]) => atomProvinceMatches(name, depo.il))?.[1];
        const center = exact || fallback || L.latLng(39, 35);
        const sameCityIndex = depoHaritaVerisi.slice(0, index).filter(x => atomNormalize(x.il) === atomNormalize(depo.il)).length;
        const ring = Math.floor(Math.max(0, sameCityIndex - 1) / 8);
        const radius = sameCityIndex === 0 ? 0 : .42 + (ring * .18);
        const angle = sameCityIndex * 2.399963229728653;
        const offset = sameCityIndex === 0 ? [0, 0] : [radius * Math.cos(angle), radius * Math.sin(angle)];
        const marker = L.marker([center.lat + offset[1], center.lng + offset[0]], {
            icon: atomCreateDepotIcon(depo),
            title: depo.ad,
            zIndexOffset: depo.icon.includes('building') ? 500 : sameCityIndex
        }).bindTooltip(atomDepotTooltip(depo), { direction: 'top', className: 'atom-map-tooltip-shell' });
        marker.on('click', () => depoGoster(depo.id));
        atomAttachMarkerDrop(marker, depo);
        atomDepotMarkerItems.push({ depo, marker });
        atomDepotMarkers.set(depo.id, marker);
    });

    if (atomProvinceLayer.getBounds().isValid()) {
        atomDepotMap.fitBounds(atomProvinceLayer.getBounds(), { padding: [18, 18] });
    }
    atomDepotMap.on('zoomend moveend', atomMarkerGorunumunuGuncelle);
    atomMarkerGorunumunuGuncelle();

    document.querySelector('[data-atom-map-reset]')?.addEventListener('click', () => {
        if (atomProvinceLayer?.getBounds().isValid()) atomDepotMap.fitBounds(atomProvinceLayer.getBounds(), { padding: [18, 18] });
    });
    varsayilanDepolariAc();
    window.addEventListener('resize', () => atomDepotMap.invalidateSize());
}

atomHaritayiBaslat().catch(error => {
    const mapEl = document.getElementById('atomDepotMap');
    if (mapEl) mapEl.innerHTML = `<div class="alert alert-danger m-3">${error.message}</div>`;
});

function depoGoster(depoId, options) {
    if (!depoId) return;
    const ayar = Object.assign({ scroll: true, focusMap: true, remember: true }, options || {});
    document.querySelectorAll('.atom-map-depo-marker').forEach(x => x.classList.remove('is-active'));
    const card = document.querySelector(`[data-depo-card="${depoId}"]`);
    if (!card) return;
    card.classList.remove('is-hidden');
    operasyonCalismaAlaniGuncelle();
    if (ayar.remember) sonDepoyaEkle(depoId);
    const marker = document.querySelector(`.atom-map-depo-marker[data-depo-id="${depoId}"]`);
    const leafletMarker = atomDepotMarkers.get(depoId);
    if (ayar.focusMap && leafletMarker && atomDepotMap) {
        if (!atomDepotMap.hasLayer(leafletMarker)) leafletMarker.addTo(atomDepotMap);
        const depo = depoHaritaVerisi.find(x => x.id === depoId);
        const hedefZoom = depo?.level === 'kurulus' ? 9 : (depo?.level === 'il' ? 7 : 6);
        atomDepotMap.setView(leafletMarker.getLatLng(), Math.max(atomDepotMap.getZoom(), hedefZoom), { animate: true });
        leafletMarker.openTooltip();
    }
    const visibleMarker = document.querySelector(`.atom-map-depo-marker[data-depo-id="${depoId}"]`);
    visibleMarker?.classList.add('is-active');
    if (ayar.scroll) card.scrollIntoView({ behavior: 'smooth', block: 'start' });
}

function depoKapat(e, depoId) {
    e.preventDefault();
    e.stopPropagation();
    document.querySelector(`[data-depo-card="${depoId}"]`)?.classList.add('is-hidden');
    sonDepodanCikar(depoId);
    operasyonCalismaAlaniGuncelle();
    document.querySelectorAll('.atom-map-depo-marker').forEach(x => {
        if (x.dataset.depoId === depoId) x.classList.remove('is-active');
    });
}

function tumDepolariGoster() {
    document.querySelectorAll('[data-depo-card]').forEach(x => x.classList.remove('is-hidden'));
    sonDepolariYaz(Array.from(document.querySelectorAll('[data-depo-card]')).map(x => x.dataset.depoCard));
    operasyonCalismaAlaniGuncelle();
    document.querySelectorAll('.atom-map-depo-marker').forEach(x => x.classList.remove('is-active'));
    if (atomProvinceLayer?.getBounds().isValid() && atomDepotMap) atomDepotMap.fitBounds(atomProvinceLayer.getBounds(), { padding: [18, 18] });
}

function surukleBasla(e, tip, depo, tanim, kayit, ad, max, ref1, ref2) {
    sur = { tip, depo, tanim, kayit, ad, max: parseInt(max) || 0, ref1: ref1 || '', ref2: ref2 || '' };
    e.dataTransfer.effectAllowed = 'move';
}
function izinVer(e) { e.preventDefault(); e.currentTarget.classList.add('dragover'); }
document.addEventListener('dragleave', e => { if (e.target.classList) e.target.classList.remove('dragover'); });
document.addEventListener('drop', e => document.querySelectorAll('.dragover').forEach(x => x.classList.remove('dragover')));

function toast(ok, msg) {
    const t = document.getElementById('toast');
    t.style.background = ok ? '#198754' : '#dc3545';
    t.innerHTML = (ok ? '<i class="bi bi-check-circle me-2"></i>' : '<i class="bi bi-x-circle me-2"></i>') + msg;
    t.style.display = 'block';
    if (ok) setTimeout(() => location.reload(), 1400);
    else setTimeout(() => t.style.display = 'none', 4000);
}
async function gonder(url, data) {
    const body = new URLSearchParams(data);
    body.append('__RequestVerificationToken', token);
    const r = await fetch(url, { method:'POST', body, headers:{'X-Requested-With':'XMLHttpRequest'} });
    const j = await r.json();
    toast(j.ok, j.msg);
}

function depoyaBirak(e, hedefDepo, hedefAd) {
    e.preventDefault();
    if (!sur) return;
    if (sur.tip === 'personel-demirbas') {
        if (sur.depo !== hedefDepo) { toast(false, 'Personel üzerindeki demirbaş yalnızca bağlı olduğu depoya iade edilebilir.'); return; }
        if (!confirm(`${sur.ad} → ${hedefAd}\nPersonel üzerindeki demirbaş bağlı depoya iade alınsın mı?`)) return;
        sonDepoyaEkle(hedefDepo);
        gonder('/Operasyon/ZimmetIadeYap', { zimmetId: sur.ref1, tasinirKayitId: sur.kayit, hedefDepoId: hedefDepo });
        return;
    }
    if (sur.tip === 'personel-sarf') {
        if (sur.depo !== hedefDepo) { toast(false, 'Personel üzerindeki sarf yalnızca verildiği bağlı depoya iade edilebilir.'); return; }
        let m = prompt(`${sur.ad} → ${hedefAd}\nİade miktarı (max ${sur.max}):`, '1');
        if (m === null) return;
        m = parseInt(m); if (!m || m < 1 || m > sur.max) { toast(false, 'Geçersiz miktar.'); return; }
        sonDepoyaEkle(hedefDepo);
        gonder('/Operasyon/PersonelSarfIadeYap', { bakiyeId: sur.kayit, hedefDepoId: hedefDepo, miktar: m });
        return;
    }
    if (sur.tip === 'demirbas') {
        if (sur.depo === hedefDepo) { toast(false, 'Aynı depo.'); return; }
        if (!confirm(`${sur.ad} → ${hedefAd}\nTekil demirbaş hedef depoya sevk edilsin mi?`)) return;
        sonDepoyaEkle(hedefDepo, sur.depo);
        gonder('/Operasyon/DemirbasSevkYap', { tasinirKayitId: sur.kayit, hedefDepoId: hedefDepo });
        return;
    }
    if (sur.depo === hedefDepo) { toast(false, 'Aynı depo.'); return; }
    if (sur.tip !== 'sarf') { toast(false, 'Bu kalem depoya bırakılamaz.'); return; }
    let m = prompt(`${sur.ad} → ${hedefAd}\nSevk miktarı (max ${sur.max}):`, '1');
    if (m === null) return;
    m = parseInt(m); if (!m || m < 1 || m > sur.max) { toast(false, 'Geçersiz miktar.'); return; }
    sonDepoyaEkle(hedefDepo, sur.depo);
    gonder('/Operasyon/SevkYap', { kaynakDepoId: sur.depo, hedefDepoId: hedefDepo, tanimId: sur.tanim, miktar: m });
}
function personeleBirak(e, personelId, personelAd) {
    e.preventDefault();
    if (!sur) return;
    if (sur.tip === 'sarf') {
        let m = prompt(`${sur.ad} → ${personelAd}\nPersonel adına tüketim miktarı (max ${sur.max}):`, '1');
        if (m === null) return;
        m = parseInt(m); if (!m || m < 1 || m > sur.max) { toast(false, 'Geçersiz miktar.'); return; }
        const kullanimYeri = prompt('Kullanım yeri / amaç:', personelAd) || personelAd;
        sonDepoyaEkle(sur.depo);
        gonder('/Operasyon/TuketimYap', { depoId: sur.depo, tanimId: sur.tanim, miktar: m, personelId, kullanimYeri });
        return;
    }
    if (sur.tip !== 'demirbas') { toast(false, 'Bu işlem türü personele bırakılamaz.'); return; }
    if (!confirm(`${sur.ad} → ${personelAd}\nZimmet oluşturulsun mu?`)) return;
    sonDepoyaEkle(sur.depo);
    gonder('/Operasyon/ZimmetYap', { tasinirKayitId: sur.kayit, personelId });
}
function hurdayaBirak(e) {
    e.preventDefault();
    if (!sur) return;
    const g = prompt(`${sur.ad} için hurda/düşüm gerekçesi:`, 'Ekonomik ömrünü doldurdu');
    if (g === null) return;
    let m = sur.tip === 'sarf' ? (parseInt(prompt(`Miktar (max ${sur.max}):`, '1')) || 0) : 1;
    if (sur.tip === 'sarf' && (m < 1 || m > sur.max)) { toast(false, 'Geçersiz miktar.'); return; }
    sonDepoyaEkle(sur.depo);
    gonder('/Operasyon/HurdaYap', { depoId: sur.depo, tanimId: sur.tanim, miktar: m, tasinirKayitId: sur.kayit || '', gerekce: g });
}
