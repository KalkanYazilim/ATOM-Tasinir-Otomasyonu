@model List<ATOM.Models.Domain.Depo>
@using ATOM.Models.Domain
@using ATOM.Models.Accounts
@using System.Security.Claims
@using System.Text.Json
@{
    ViewData["Title"] = "Operasyon Panosu";
    var kullaniciAnahtari = User.FindFirstValue(ClaimTypes.NameIdentifier) ?? User.Identity?.Name ?? "anonim";
    var tanimlar = ViewBag.Tanimlar as Dictionary<string, TasinirTanim> ?? new();
    var personeller = ViewBag.Personeller as List<AtomKullanici> ?? new();
    var depoTekiller = ViewBag.DepoTekiller as Dictionary<string, List<TasinirKayit>> ?? new();
    var kurumDetaylari = ViewBag.KurumDetaylari as Dictionary<string, Kurum> ?? new();
    var personelZimmetleri = ViewBag.PersonelZimmetleri as Dictionary<string, List<Zimmet>> ?? new();
    var personelSarfBakiyeleri = ViewBag.PersonelSarfBakiyeleri as Dictionary<string, List<PersonelSarfBakiye>> ?? new();
    var personelBagliDepolari = ViewBag.PersonelBagliDepolari as Dictionary<string, List<string>> ?? new();
    string TanimAd(string id) => tanimlar.TryGetValue(id, out var t) ? t.Ad : id;
    string DepoIl(Depo depo) => kurumDetaylari.TryGetValue(depo.KurumId, out var kurum) && !string.IsNullOrWhiteSpace(kurum.Il) ? kurum.Il : "Ankara";
    string DepoSeviye(Depo depo)
    {
        if (depo.MerkezDepoMu || depo.KurumId == "k-bakanlik") return "merkez";
        if (depo.Kod.EndsWith("-ANA", StringComparison.OrdinalIgnoreCase) ||
            depo.Ad.Contains("İl Müdürlüğü Ana Deposu", StringComparison.OrdinalIgnoreCase) ||
            depo.Ad.Contains("İl Deposu", StringComparison.OrdinalIgnoreCase)) return "il";
        return "kurulus";
    }
    string DepoIcon(Depo depo) => DepoSeviye(depo) switch
    {
        "merkez" => "bi-building-fill-gear",
        "il" => "bi-buildings-fill",
        _ => "bi-box-seam-fill"
    };
    string DepoRenk(Depo depo) => DepoSeviye(depo) switch
    {
        "merkez" => "#1a3a6b",
        "il" => "#0d6efd",
        _ => "#198754"
    };
    var depoHaritaVerisi = Model.Select(depo => new
    {
        id = depo.Id,
        ad = depo.Ad,
        il = DepoIl(depo),
        toplam = depo.Stoklar.Sum(s => s.Miktar),
        sarf = depo.Stoklar.Count(s => s.Miktar > 0 && tanimlar.GetValueOrDefault(s.TasinirTanimId)?.DemirbasMi != true),
        demirbas = depoTekiller.TryGetValue(depo.Id, out var tekiller) ? tekiller.Count : 0,
        icon = DepoIcon(depo),
        color = DepoRenk(depo),
        level = DepoSeviye(depo),
        adres = depo.Adres
    }).ToList();
    var depoHaritaJson = JsonSerializer.Serialize(depoHaritaVerisi, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
}
@section Breadcrumb { <ol class="breadcrumb mb-0"><li class="breadcrumb-item active">Operasyon Panosu</li></ol> }

@Html.AntiForgeryToken()

<div class="d-flex justify-content-between align-items-center mb-2">
    <h5 class="mb-0 fw-bold"><i class="bi bi-grid-1x2 me-2 text-primary"></i>Operasyon Panosu
        <span class="text-muted fw-normal small">— sürükle-bırak ile sevk / zimmet / hurda</span></h5>
</div>
<div class="alert alert-info py-2 small">
    <i class="bi bi-info-circle me-1"></i>
    <strong>Sarf</strong> kalemini başka depoya sürükle → <strong>sevk</strong>.
    <strong>Demirbaş</strong> kartını bir personele sürükle → <strong>zimmet</strong>.
    Herhangi bir kalemi <strong>Hurda</strong> alanına sürükle → <strong>düşüm talebi</strong>.
    Tüm işlemler stok/taşınır servislerinden geçer, negatif stok engellenir.
</div>

<div class="row g-3 align-items-stretch operasyon-ust-panel mb-3">
<div class="col-xl-9">
<div class="card turkiye-map-panel h-100">
    <div class="card-header bg-white d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
            <div class="fw-semibold"><i class="bi bi-map me-2 text-primary"></i>Türkiye Depo Haritası</div>
            <div class="small text-muted">İl sınırları PazarCep harita verisi ile çizilir; depo ikonları gerçek il sınırının merkezine yerleşir.</div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-sm btn-outline-secondary" data-atom-map-reset>
                <i class="bi bi-arrows-fullscreen me-1"></i>Türkiye
            </button>
            <button type="button" class="btn btn-sm btn-outline-primary" data-show-all-depots onclick="tumDepolariGoster()">
                <i class="bi bi-grid-3x3-gap me-1"></i>Tüm depolar
            </button>
        </div>
    </div>
    <div class="atom-map-shell">
        <div id="atomDepotMap" class="atom-depot-map" data-atom-depot-map></div>
        <div class="atom-map-legend">
            <span><i class="bi bi-building-fill-gear"></i> Merkez depo</span>
            <span><i class="bi bi-buildings-fill"></i> İl ana deposu</span>
            <span><i class="bi bi-box-seam-fill"></i> Kuruluş deposu</span>
            <span class="text-muted">Yaklaştıkça küçük depolar açılır; ürün sürükleyip depo ikonuna bırakabilirsiniz.</span>
        </div>
    </div>
</div>
</div>

<div class="col-xl-3">
    <div class="card h-100 personel-panel">
        <div class="card-header bg-danger text-white fw-semibold"><i class="bi bi-trash3 me-2"></i>Hurda / Düşüm Alanı</div>
        <div class="card-body p-2 border-bottom">
            <div class="drop-hurda text-center py-3 border border-danger rounded" ondragover="izinVer(event)" ondrop="hurdayaBirak(event)">
                <i class="bi bi-trash3 text-danger me-1"></i><span class="small text-muted">Düşüm yapılacak kalemi buraya bırakın</span>
            </div>
        </div>
        <div class="card-header bg-success text-white fw-semibold"><i class="bi bi-people me-2"></i>Personel / Üzerindeki Malzemeler</div>
        <div class="card-body p-2 personel-panel-body">
            @foreach (var depo in Model)
            {
                var depoPersonelleri = personeller
                    .Where(p => (personelBagliDepolari.GetValueOrDefault(p.Id) ?? new()).Contains(depo.Id))
                    .OrderBy(p => p.AdSoyad)
                    .ToList();
                if (!depoPersonelleri.Any()) { continue; }
                <div class="personel-depo-grup mb-3" data-personel-depo-group="@depo.Id">
                    <div class="personel-depo-baslik">
                        <i class="bi bi-building-check"></i>
                        <span>@depo.Ad</span>
                        <small>@DepoIl(depo)</small>
                    </div>
                    @foreach (var p in depoPersonelleri)
                    {
                        var aktifZimmetler = (personelZimmetleri.GetValueOrDefault(p.Id) ?? new()).Where(z => z.DepoId == depo.Id).ToList();
                        var aktifSarf = (personelSarfBakiyeleri.GetValueOrDefault(p.Id) ?? new()).Where(b => b.KaynakDepoId == depo.Id).ToList();
                        <div class="drop-personel mb-2 p-2 rounded border"
                             data-personel="@p.Id" data-personel-depo="@depo.Id" ondragover="izinVer(event)" ondrop="personeleBirak(event,'@p.Id','@p.AdSoyad')">
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-person-circle text-success"></i>
                                <span class="small fw-semibold">@p.AdSoyad</span>
                                <span class="ms-auto badge bg-light text-dark">@aktifZimmetler.Sum(z => z.Kalemler.Count(k => k.ItemDurumu == ZimmetDurumu.Aktif)) zimmet</span>
                            </div>
                            <div class="personel-bagli-depo"><i class="bi bi-link-45deg"></i>Bağlı depo: @depo.Ad</div>
                            @if (aktifZimmetler.Any())
                            {
                                <div class="personel-zimmet-list mt-2">
                                    @foreach (var z in aktifZimmetler.Take(4))
                                    {
                                        foreach (var kalem in z.Kalemler.Where(k => k.ItemDurumu == ZimmetDurumu.Aktif).Take(4))
                                        {
                                            <div class="personel-zimmet-item" draggable="true"
                                                 title="Bağlı depo: @depo.Ad"
                                                 ondragstart="surukleBasla(event,'personel-demirbas','@z.DepoId','@kalem.TasinirTanimId','@kalem.TasinirKayitId','@TanimAd(kalem.TasinirTanimId)','1','@z.Id','@p.Id')">
                                                <i class="bi bi-cpu text-warning"></i>
                                                <span>@TanimAd(kalem.TasinirTanimId)</span>
                                                <small>@kalem.SicilNo</small>
                                            </div>
                                        }
                                    }
                                </div>
                            }
                            @if (aktifSarf.Any())
                            {
                                <div class="personel-sarf-list mt-2">
                                    @foreach (var b in aktifSarf.Take(4))
                                    {
                                        <span class="personel-sarf-chip" draggable="true"
                                              title="Bağlı depo: @depo.Ad"
                                              ondragstart="surukleBasla(event,'personel-sarf','@b.KaynakDepoId','@b.TasinirTanimId','@b.Id','@TanimAd(b.TasinirTanimId)','@b.Miktar','','@p.Id')">
                                            <i class="bi bi-basket2"></i>@TanimAd(b.TasinirTanimId) ×@b.Miktar
                                        </span>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            }
            @foreach (var p in personeller.Where(p => !(personelBagliDepolari.GetValueOrDefault(p.Id) ?? new()).Any()).OrderBy(p => p.AdSoyad))
            {
                <div class="drop-personel personel-baglantisiz mb-2 p-2 rounded border"
                     data-personel="@p.Id" ondragover="izinVer(event)" ondrop="personeleBirak(event,'@p.Id','@p.AdSoyad')">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-person-circle text-success"></i>
                        <span class="small fw-semibold">@p.AdSoyad</span>
                    </div>
                    <div class="personel-bagli-depo text-muted"><i class="bi bi-link-45deg"></i>Bağlı depo/zimmet kaydı yok</div>
                </div>
            }
            @if (!personeller.Any()) { <div class="text-muted small">Personel yok.</div> }
        </div>
    </div>
</div>
</div>

<div id="operationWorkspace" class="row g-3 operation-workspace is-empty">
    <div class="col-12">
        <div class="row g-3">
        @foreach (var depo in Model)
        {
            var depoIl = DepoIl(depo);
            <div class="col-md-6 depo-card-col is-hidden" id="depo-card-@depo.Id" data-depo-card="@depo.Id">
                <div class="card h-100 depo-kart" data-depo="@depo.Id" ondragover="izinVer(event)" ondrop="depoyaBirak(event,'@depo.Id','@depo.Ad')">
                    <div class="card-header bg-primary text-white fw-semibold d-flex justify-content-between align-items-start gap-2">
                        <span class="depo-title"><i class="bi bi-building me-2"></i>@depo.Ad <small class="d-block fw-normal opacity-75">@depoIl</small></span>
                        <span class="d-inline-flex align-items-center gap-2">
                            <span class="badge bg-light text-dark">@depo.Stoklar.Sum(s => s.Miktar) adet</span>
                            <button type="button" class="btn-close btn-close-white depo-close" aria-label="@depo.Ad kartını kapat" onclick="depoKapat(event,'@depo.Id')"></button>
                        </span>
                    </div>
                    <div class="card-body p-2">
                        <div class="text-muted small mb-1"><i class="bi bi-box-seam me-1"></i>Sarf / Stok</div>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                        @foreach (var s in depo.Stoklar.Where(x => x.Miktar > 0))
                        {
                            var t = tanimlar.GetValueOrDefault(s.TasinirTanimId);
                            if (t?.DemirbasMi == true) { continue; }
                            <span class="chip sarf" draggable="true"
                                  data-tanim-id="@s.TasinirTanimId" data-urun-resim="@(t?.ResimUrl)" data-urun-ad="@(t?.Ad)"
                                  ondragstart="surukleBasla(event,'sarf','@depo.Id','@s.TasinirTanimId','','@(t?.Ad)','@s.Miktar')">
                                @if (!string.IsNullOrEmpty(t?.ResimUrl)) { <img src="@t.ResimUrl" class="chip-img"/> } else { <i class="bi bi-box"></i> }
                                @TanimAd(s.TasinirTanimId) <b>×@s.Miktar</b>
                            </span>
                        }
                        </div>
                        <div class="text-muted small mb-1"><i class="bi bi-upc-scan me-1"></i>Demirbaş (tekil)</div>
                        <div class="d-flex flex-wrap gap-1">
                        @if (depoTekiller.TryGetValue(depo.Id, out var tekiller))
                        {
                            foreach (var k in tekiller.Take(40))
                            {
                                var t = tanimlar.GetValueOrDefault(k.TasinirTanimId ?? "");
                                <span class="chip demirbas" draggable="true" title="@k.SicilNo"
                                      data-tanim-id="@k.TasinirTanimId" data-urun-resim="@(k.ResimUrl ?? t?.ResimUrl)" data-urun-ad="@k.Cinsi" data-urun-alt="Sicil: @k.SicilNo"
                                      ondragstart="surukleBasla(event,'demirbas','@depo.Id','@(k.TasinirTanimId)','@k.Id','@k.Cinsi','1')">
                                    @if (!string.IsNullOrEmpty(k.ResimUrl ?? t?.ResimUrl)) { <img src="@(k.ResimUrl ?? t?.ResimUrl)" class="chip-img"/> } else { <i class="bi bi-cpu"></i> }
                                    @k.Cinsi <span class="text-muted">@k.SicilNo</span>
                                </span>
                            }
                        }
                        else { <span class="text-muted small">Tekil demirbaş yok.</span> }
                        </div>
                    </div>
                </div>
            </div>
        }
        @if (!Model.Any()) { <div class="col-12"><div class="alert alert-warning">Görüntülenecek depo yok.</div></div> }
        </div>
    </div>
</div>

<div id="toast" class="position-fixed bottom-0 end-0 m-3 p-3 rounded text-white shadow" style="display:none;z-index:2000;min-width:280px;"></div>

