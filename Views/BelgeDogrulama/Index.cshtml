@using ATOM.Models.Domain
@{
    Layout = null;
    var imza = ViewBag.Imza as ElektronikImza;
    var kod = ViewBag.Kod as string;
}
<!DOCTYPE html>
<html lang="tr"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Belge Doğrulama – ATOM</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
<style>body{background:linear-gradient(135deg,#1a3a6b,#2d6a9f);min-height:100vh;display:flex;align-items:center;}</style>
</head><body>
<div class="container" style="max-width:560px;">
    <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-4">
            <div class="text-center mb-3">
                <div style="font-size:1.8rem;font-weight:800;letter-spacing:3px;color:#1a3a6b;"><i class="bi bi-shield-check me-2"></i>ATOM</div>
                <div class="text-muted small">Elektronik Belge Doğrulama (5070 sayılı Kanun)</div>
            </div>
            <form method="get" class="mb-3">
                <div class="input-group">
                    <input name="kod" value="@kod" class="form-control" placeholder="Doğrulama kodu: ATOM-XXXX-XXXX-XXXX" required/>
                    <button class="btn btn-primary"><i class="bi bi-search me-1"></i>Doğrula</button>
                </div>
            </form>

            @if (!string.IsNullOrEmpty(kod))
            {
                if (imza != null)
                {
                    <div class="alert alert-success">
                        <h6 class="fw-bold"><i class="bi bi-patch-check-fill me-1"></i>Belge Doğrulandı</h6>
                        <hr/>
                        <div class="row g-2 small">
                            <div class="col-5 text-muted">Belge Türü</div><div class="col-7 fw-semibold">@imza.BelgeTuru</div>
                            <div class="col-5 text-muted">Belge No</div><div class="col-7 fw-semibold">@imza.BelgeNo</div>
                            <div class="col-5 text-muted">İmzalayan</div><div class="col-7 fw-semibold">@imza.ImzalayanAdSoyad</div>
                            <div class="col-5 text-muted">Kurum</div><div class="col-7">@imza.Kurum</div>
                            <div class="col-5 text-muted">İmza Tipi</div><div class="col-7">@imza.ImzaTipi</div>
                            <div class="col-5 text-muted">İmza Tarihi</div><div class="col-7">@imza.ImzaTarihi.ToString("dd.MM.yyyy HH:mm")</div>
                            <div class="col-5 text-muted">SHA-256</div><div class="col-7" style="word-break:break-all;font-size:.7rem;">@imza.BelgeHash</div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger"><i class="bi bi-x-octagon-fill me-1"></i>Bu doğrulama koduna ait belge bulunamadı.</div>
                }
            }
            <div class="text-center"><a href="/giris" class="small text-muted">ATOM Girişine Dön</a></div>
        </div>
    </div>
</div>
</body></html>
