@using System.Security.Claims
@using ATOM.Models.Accounts
@{
    var kullaniciAdi = User.FindFirstValue("AdSoyad") ?? User.Identity?.Name ?? "";
    var rol = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var rolAdi = AtomRoller.DisplayName(rol);
    bool girisYapildi = User.Identity?.IsAuthenticated == true;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ATOM Taşınır Otomasyonu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --atom-primary: #1a3a6b;
            --atom-secondary: #2d6a9f;
            --atom-accent: #e8a020;
            --atom-sidebar-w: 260px;
            /* Hiyerarşik derinlik (elevation) katmanları */
            --elev-1: 0 1px 2px rgba(31,45,71,.10), 0 1px 1px rgba(31,45,71,.06);
            --elev-2: 0 2px 5px rgba(31,45,71,.12), 0 1px 2px rgba(31,45,71,.08);
            --elev-3: 0 6px 14px rgba(31,45,71,.16), 0 2px 4px rgba(31,45,71,.10);
            --elev-4: 0 12px 28px rgba(31,45,71,.20), 0 5px 10px rgba(31,45,71,.12);
            --elev-5: 0 22px 48px rgba(31,45,71,.26), 0 8px 16px rgba(31,45,71,.16);
        }
        /* En arka katman: body biraz çukur/recessed dursun ki üstündekiler öne çıksın */
        body { font-family: 'Segoe UI', sans-serif; background: #e7ecf3;
               background-image: radial-gradient(circle at 50% 0, #eef2f7, #e2e8f1); }
        #sidebar {
            width: var(--atom-sidebar-w); height: 100vh;
            background: var(--atom-primary); position: fixed; left: 0; top: 0; z-index: 100;
            transition: transform .25s ease;
            display: flex; flex-direction: column;
        }
        #sidebar .brand {
            padding: 1.2rem 1rem; background: rgba(0,0,0,.25);
            border-bottom: 1px solid rgba(255,255,255,.1);
            flex-shrink: 0;
        }
        #sidebar .menu-scroll {
            flex: 1 1 auto; overflow-y: auto; overflow-x: hidden;
            scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.3) transparent;
        }
        #sidebar .menu-scroll::-webkit-scrollbar { width: 7px; }
        #sidebar .menu-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,.25); border-radius: 4px; }
        #sidebar .menu-scroll::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,.45); }
        #sidebar .logo-text { color: #fff; font-size: 1.5rem; font-weight: 700; letter-spacing: 3px; }
        #sidebar .sub-text { color: rgba(255,255,255,.55); font-size: .68rem; }
        #sidebar .nav-link {
            color: rgba(255,255,255,.8); padding: .55rem 1.2rem;
            border-radius: .3rem; margin: .1rem .5rem;
            display: flex; align-items: center; gap: .6rem; font-size: .88rem;
        }
        #sidebar .nav-link:hover, #sidebar .nav-link.active {
            background: rgba(255,255,255,.13); color: #fff;
        }
        #sidebar .nav-section {
            font-size: .62rem; text-transform: uppercase; letter-spacing: 1.2px;
            color: rgba(255,255,255,.38); padding: .8rem 1.2rem .2rem;
        }
        #main-content { margin-left: var(--atom-sidebar-w); }
        .topbar {
            background: #fff; border-bottom: 1px solid #e0e0e0;
            padding: .6rem 1.5rem; position: sticky; top: 0; z-index: 99;
            display: flex; align-items: center; justify-content: space-between;
        }
        .page-content { padding: 1.5rem; }
        .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,.08); border-radius: .5rem; }
        .stat-card { border-left: 4px solid var(--atom-secondary); }
        .stat-card.danger { border-left-color: #dc3545; }
        .stat-card.warning { border-left-color: #ffc107; }
        .stat-card.success { border-left-color: #198754; }
        .stat-card.info { border-left-color: #0dcaf0; }
        .durum-badge { font-size: .75rem; padding: .25rem .6rem; border-radius: 1rem; font-weight: 600; }

        /* ═══════════════════════════════════════════════════════
           HİYERARŞİK DERİNLİK — her nesne bir altındakinin önünde
           ═══════════════════════════════════════════════════════ */

        /* Katman 1: Sidebar (menü) — body'nin önünde, sağ kenara gölge düşürür */
        #sidebar { box-shadow: 5px 0 22px rgba(15,28,50,.35); z-index: 110; }
        #sidebar .brand { box-shadow: 0 2px 8px rgba(0,0,0,.30); position: relative; z-index: 2; }
        #sidebar .logo-text, #sidebar .sub-text,
        #sidebar .nav-section { text-shadow: 0 1px 2px rgba(0,0,0,.45); }

        /* Katman 2: Menü içindeki linkler — menünün önünde; hover'da kabarır */
        #sidebar .nav-link { transition: transform .15s ease, box-shadow .15s ease, background .15s ease; }
        #sidebar .nav-link i { text-shadow: 0 1px 2px rgba(0,0,0,.5); transition: transform .15s ease; }
        #sidebar .nav-link span, #sidebar .nav-link { text-shadow: 0 1px 1px rgba(0,0,0,.35); }
        #sidebar .nav-link:hover {
            transform: translateX(4px);
            box-shadow: 0 4px 12px rgba(0,0,0,.35);
            background: rgba(255,255,255,.18);
        }
        #sidebar .nav-link.active {
            background: rgba(255,255,255,.16);
            box-shadow: inset 3px 0 0 var(--atom-accent), 0 4px 12px rgba(0,0,0,.30);
        }
        #sidebar .nav-link:hover i { transform: scale(1.15); }

        /* Topbar — içeriğin önünde, alta gölge */
        .topbar { box-shadow: 0 3px 10px rgba(31,45,71,.12); z-index: 105; }

        /* Katman 2: Kartlar — sayfa zemininin önünde */
        .card { box-shadow: var(--elev-2); transition: box-shadow .2s ease; }
        .card:hover { box-shadow: var(--elev-3); }
        /* Kart içindeki başlık — kartın yüzeyinden hafif kabarık */
        .card > .card-header {
            box-shadow: 0 2px 6px rgba(31,45,71,.08);
            position: relative; z-index: 1;
        }
        /* Kart içindeki kart (iç içe) daha öne çıksın */
        .card .card { box-shadow: var(--elev-3); }
        .card .card:hover { box-shadow: var(--elev-4); }

        /* Stat kartları kendi renkleriyle gölge */
        .stat-card { box-shadow: var(--elev-2); }
        .stat-card:hover { transform: none; }
        .stat-card.danger:hover  { box-shadow: 0 8px 20px rgba(220,53,69,.30); }
        .stat-card.warning:hover { box-shadow: 0 8px 20px rgba(255,193,7,.32); }
        .stat-card.success:hover { box-shadow: 0 8px 20px rgba(25,135,84,.30); }
        .stat-card.info:hover    { box-shadow: 0 8px 20px rgba(13,202,240,.30); }

        /* Katman 3: Butonlar — kabın önünde, KENDİ RENGİNDE gölge */
        .btn {
            transition: box-shadow .12s ease, filter .12s ease;
            box-shadow: var(--elev-2);
        }
        .btn:hover { filter: brightness(1.04); box-shadow: var(--elev-3); }
        .btn:active { filter: brightness(.98); box-shadow: var(--elev-1); }
        /* Buton yazısı/ikonu daha önde dursun */
        .btn:not(.btn-outline-secondary):not(.btn-outline-primary):not(.btn-light) {
            text-shadow: 0 1px 1px rgba(0,0,0,.25);
        }
        /* Dolu butonlar — kendi renginde renkli gölge */
        .btn-primary   { box-shadow: 0 3px 8px rgba(13,110,253,.40); }
        .btn-primary:hover   { box-shadow: 0 7px 16px rgba(13,110,253,.50); }
        .btn-success   { box-shadow: 0 3px 8px rgba(25,135,84,.40); }
        .btn-success:hover   { box-shadow: 0 7px 16px rgba(25,135,84,.50); }
        .btn-danger    { box-shadow: 0 3px 8px rgba(220,53,69,.40); }
        .btn-danger:hover    { box-shadow: 0 7px 16px rgba(220,53,69,.50); }
        .btn-warning   { box-shadow: 0 3px 8px rgba(255,193,7,.45); }
        .btn-warning:hover   { box-shadow: 0 7px 16px rgba(255,193,7,.55); }
        .btn-info      { box-shadow: 0 3px 8px rgba(13,202,240,.40); }
        .btn-info:hover      { box-shadow: 0 7px 16px rgba(13,202,240,.50); }
        .btn-secondary { box-shadow: 0 3px 8px rgba(108,117,125,.35); }
        .btn-outline-primary, .btn-outline-secondary, .btn-outline-success,
        .btn-outline-danger, .btn-outline-warning, .btn-outline-info { box-shadow: var(--elev-1); }

        /* Rozetler — kendi renginde hafif gölge, yüzeyden kabarık */
        .badge { box-shadow: 0 2px 4px rgba(31,45,71,.18); text-shadow: 0 1px 1px rgba(0,0,0,.22); }

        /* Form alanları — yüzeyin önünde, odakta öne çıkar */
        .form-control, .form-select {
            box-shadow: var(--elev-1); transition: box-shadow .15s ease;
        }
        .form-control:focus, .form-select:focus {
            box-shadow: 0 0 0 .2rem rgba(45,106,159,.20), var(--elev-2);
        }

        /* Tablo başlığı — satırların önünde, hafif gölge */
        .table thead th { box-shadow: 0 2px 4px rgba(31,45,71,.10); }
        .table-hover tbody tr { transition: transform .12s ease, box-shadow .12s ease; }
        .table-hover tbody tr:hover { box-shadow: 0 3px 10px rgba(31,45,71,.14); position: relative; z-index: 1; }

        /* Modal — en önde yüzer */
        .modal-content { box-shadow: var(--elev-5); border: none; }

        /* Başlıklar hafif kabarık */
        h4, h5, h6 { text-shadow: 0 1px 1px rgba(31,45,71,.10); }

        /* Liste grupları — öğeler hover'da öne çıkar */
        .list-group-item { transition: background .12s ease, box-shadow .12s ease; }
        .list-group-item:hover { box-shadow: var(--elev-1); position: relative; z-index: 1; }

        @@media (max-width: 768px) {
            #sidebar { transform: translateX(-100%); }
            #sidebar.show { transform: translateX(0); }
            #main-content { margin-left: 0; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

@if (girisYapildi)
{
    <nav id="sidebar">
        <div class="brand">
            <div class="logo-text"><i class="bi bi-box-seam me-2"></i>ATOM</div>
            <div class="sub-text">Taşınır Malzeme Otomasyonu</div>
        </div>
        <div class="menu-scroll pb-4 pt-2">
            <div class="nav-section">Ana Menü</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
               href="@Url.Action("Index","Dashboard")">
                <i class="bi bi-speedometer2"></i> Gösterge Paneli
            </a>
            @if (rol != AtomRoller.Tedarikci && rol != AtomRoller.Personel && rol != AtomRoller.Teknisyen)
            {
                <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Operasyon" ? "active" : "")"
                   href="/Operasyon"><i class="bi bi-grid-1x2"></i> Operasyon Panosu</a>
            }

            @if (rol != AtomRoller.Tedarikci)
            {
                <div class="nav-section">Talepler</div>
                <a class="nav-link" href="/talep"><i class="bi bi-clipboard2-plus"></i> İhtiyaç Talepleri</a>
            }

            <div class="nav-section">Satın Alma</div>
            <a class="nav-link" href="/ihale"><i class="bi bi-hammer"></i> İhale Yönetimi</a>

            @if (rol != AtomRoller.Tedarikci && rol != AtomRoller.Personel)
            {
                <div class="nav-section">Mal Hareketi</div>
                <a class="nav-link" href="/edinim/Giris"><i class="bi bi-box-arrow-in-down"></i> Mal Girişi (Edinim)</a>
                <a class="nav-link" href="/edinim/Cikis"><i class="bi bi-box-arrow-up"></i> Mal Çıkışı</a>

                <div class="nav-section">Lojistik & Depo</div>
                <a class="nav-link" href="/kayit"><i class="bi bi-upc-scan"></i> Taşınır Kayıtları</a>
                <a class="nav-link" href="/depo"><i class="bi bi-building"></i> Depo & Stok</a>
                <a class="nav-link" href="/depo/Home/Sevkler"><i class="bi bi-truck"></i> Sevk İşlemleri</a>
                <a class="nav-link" href="/depo/Home/MalKabuller"><i class="bi bi-box-arrow-in-down"></i> Mal Kabul</a>
                <a class="nav-link" href="/depo/Home/TuketimCikisi"><i class="bi bi-box-arrow-up"></i> Tüketim Çıkışı</a>
            }

            <div class="nav-section">Zimmet</div>
            <a class="nav-link" href="/zimmet"><i class="bi bi-person-badge"></i> Zimmet Listesi</a>
            <a class="nav-link" href="/zimmet/Home/Bakim"><i class="bi bi-tools"></i> Bakım & Arıza</a>

            @if (rol != AtomRoller.Tedarikci && rol != AtomRoller.Personel)
            {
                <div class="nav-section">Taşınır İşlemleri</div>
                <a class="nav-link" href="/sayim"><i class="bi bi-clipboard-check"></i> Sayım</a>
                <a class="nav-link" href="/devir"><i class="bi bi-arrow-left-right"></i> Devir</a>
                <a class="nav-link" href="/hurda"><i class="bi bi-trash3"></i> Hurda / Düşüm</a>
                <a class="nav-link" href="/tasit"><i class="bi bi-truck-front"></i> Taşıt Yönetimi</a>
            }

            @if (AtomRoller.BakanlikRolleri.Contains(rol) || rol == AtomRoller.IlMuduru)
            {
                <div class="nav-section">Analiz</div>
                <a class="nav-link" href="/raporlama"><i class="bi bi-bar-chart-line"></i> Raporlar & Analiz</a>
            }

            @if (rol == AtomRoller.SistemAdmin || rol == AtomRoller.BakanlikMerkez)
            {
                <div class="nav-section">Yönetim</div>
                <a class="nav-link" href="/yonetim"><i class="bi bi-gear"></i> Sistem Yönetimi</a>
                <a class="nav-link" href="/yonetim/Home/Kullanicilar"><i class="bi bi-people"></i> Kullanıcılar</a>
                <a class="nav-link" href="/yonetim/Home/Kurumlar"><i class="bi bi-bank"></i> Kurumlar</a>
                <a class="nav-link" href="/yonetim/Home/Firmalar"><i class="bi bi-briefcase"></i> Firmalar</a>
                <a class="nav-link" href="/yonetim/Home/TasinirTanimlar"><i class="bi bi-tags"></i> Taşınır Tanımları</a>
                <a class="nav-link" href="/yonetim/Home/AuditLog"><i class="bi bi-journal-text"></i> İşlem Kayıtları</a>
                <a class="nav-link" href="/resmi-yazi"><i class="bi bi-file-earmark-text"></i> Resmi Yazı (EBYS)</a>
            }
        </div>
    </nav>

    <div id="main-content">
        <div class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-outline-secondary d-md-none" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="bi bi-list"></i>
                </button>
                @RenderSection("Breadcrumb", required: false)
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (TempData["Basari"] != null)
                {
                    <span class="badge bg-success fs-6 fw-normal"><i class="bi bi-check-circle me-1"></i>@TempData["Basari"]</span>
                }
                @if (TempData["Hata"] != null)
                {
                    <span class="badge bg-danger fs-6 fw-normal"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Hata"]</span>
                }
                @await Component.InvokeAsync("BildirimCani")
                <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>@kullaniciAdi</span>
                <span class="badge rounded-pill" style="background:var(--atom-secondary);font-size:.7rem;">@rolAdi</span>
                <form method="post" action="/cikis" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Çıkış">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
        <div class="page-content">
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
// Sayfadaki tüm barkod ve QR alanlarını otomatik çiz
function atomKodlariCiz() {
    document.querySelectorAll('svg.atom-barcode:not([data-done])').forEach(function(el){
        try {
            JsBarcode(el, el.getAttribute('data-value') || '', {
                format: 'CODE128',
                height: parseInt(el.getAttribute('data-height') || '38'),
                width: parseFloat(el.getAttribute('data-bw') || '1.6'),
                fontSize: parseInt(el.getAttribute('data-fs') || '12'),
                margin: 4, displayValue: el.getAttribute('data-text') !== 'false'
            });
            el.setAttribute('data-done','1');
        } catch(e) { /* gecersiz deger */ }
    });
    document.querySelectorAll('.atom-qr:not([data-done])').forEach(function(el){
        var v = el.getAttribute('data-value') || '';
        if (!v) return;
        var s = parseInt(el.getAttribute('data-size') || '90');
        new QRCode(el, { text: v, width: s, height: s, correctLevel: QRCode.CorrectLevel.M });
        el.setAttribute('data-done','1');
    });
}
document.addEventListener('DOMContentLoaded', atomKodlariCiz);
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
