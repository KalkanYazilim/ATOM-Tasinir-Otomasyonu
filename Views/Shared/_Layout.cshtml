@using System.Security.Claims
@using ATOM.Models.Accounts
@{
    var kullaniciAdi = User.FindFirstValue("AdSoyad") ?? User.Identity?.Name ?? "";
    var rol = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var rolAdi = AtomRoller.DisplayName(rol);
    bool girisYapildi = User.Identity?.IsAuthenticated == true;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – ATOM Taşınır Otomasyonu</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --atom-primary: #1a3a6b;
            --atom-secondary: #2d6a9f;
            --atom-accent: #e8a020;
            --atom-sidebar-w: 260px;
        }
        body { font-family: 'Segoe UI', sans-serif; background: #f4f6f9; }
        #sidebar {
            width: var(--atom-sidebar-w); height: 100vh;
            background: var(--atom-primary); position: fixed; left: 0; top: 0; z-index: 100;
            transition: transform .25s ease;
            display: flex; flex-direction: column;
        }
        #sidebar .brand {
            padding: 1.2rem 1rem; background: rgba(0,0,0,.25);
            border-bottom: 1px solid rgba(255,255,255,.1);
            flex-shrink: 0;
        }
        #sidebar .menu-scroll {
            flex: 1 1 auto; overflow-y: auto; overflow-x: hidden;
            scrollbar-width: thin; scrollbar-color: rgba(255,255,255,.3) transparent;
        }
        #sidebar .menu-scroll::-webkit-scrollbar { width: 7px; }
        #sidebar .menu-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,.25); border-radius: 4px; }
        #sidebar .menu-scroll::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,.45); }
        #sidebar .logo-text { color: #fff; font-size: 1.5rem; font-weight: 700; letter-spacing: 3px; }
        #sidebar .sub-text { color: rgba(255,255,255,.55); font-size: .68rem; }
        #sidebar .nav-link {
            color: rgba(255,255,255,.8); padding: .55rem 1.2rem;
            border-radius: .3rem; margin: .1rem .5rem;
            display: flex; align-items: center; gap: .6rem; font-size: .88rem;
        }
        #sidebar .nav-link:hover, #sidebar .nav-link.active {
            background: rgba(255,255,255,.13); color: #fff;
        }
        #sidebar .nav-section {
            font-size: .62rem; text-transform: uppercase; letter-spacing: 1.2px;
            color: rgba(255,255,255,.38); padding: .8rem 1.2rem .2rem;
        }
        #main-content { margin-left: var(--atom-sidebar-w); }
        .topbar {
            background: #fff; border-bottom: 1px solid #e0e0e0;
            padding: .6rem 1.5rem; position: sticky; top: 0; z-index: 99;
            display: flex; align-items: center; justify-content: space-between;
        }
        .page-content { padding: 1.5rem; }
        .card { border: none; box-shadow: 0 1px 4px rgba(0,0,0,.08); border-radius: .5rem; }
        .stat-card { border-left: 4px solid var(--atom-secondary); }
        .stat-card.danger { border-left-color: #dc3545; }
        .stat-card.warning { border-left-color: #ffc107; }
        .stat-card.success { border-left-color: #198754; }
        .stat-card.info { border-left-color: #0dcaf0; }
        .durum-badge { font-size: .75rem; padding: .25rem .6rem; border-radius: 1rem; font-weight: 600; }
        @@media (max-width: 768px) {
            #sidebar { transform: translateX(-100%); }
            #sidebar.show { transform: translateX(0); }
            #main-content { margin-left: 0; }
        }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

@if (girisYapildi)
{
    <nav id="sidebar">
        <div class="brand">
            <div class="logo-text"><i class="bi bi-box-seam me-2"></i>ATOM</div>
            <div class="sub-text">Taşınır Malzeme Otomasyonu</div>
        </div>
        <div class="menu-scroll pb-4 pt-2">
            <div class="nav-section">Ana Menü</div>
            <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")"
               href="@Url.Action("Index","Dashboard")">
                <i class="bi bi-speedometer2"></i> Gösterge Paneli
            </a>

            @if (rol != AtomRoller.Tedarikci)
            {
                <div class="nav-section">Talepler</div>
                <a class="nav-link" href="/talep"><i class="bi bi-clipboard2-plus"></i> İhtiyaç Talepleri</a>
            }

            <div class="nav-section">Satın Alma</div>
            <a class="nav-link" href="/ihale"><i class="bi bi-hammer"></i> İhale Yönetimi</a>

            @if (rol != AtomRoller.Tedarikci && rol != AtomRoller.Personel)
            {
                <div class="nav-section">Lojistik & Depo</div>
                <a class="nav-link" href="/kayit"><i class="bi bi-upc-scan"></i> Taşınır Kayıtları</a>
                <a class="nav-link" href="/depo"><i class="bi bi-building"></i> Depo & Stok</a>
                <a class="nav-link" href="/depo/Home/Sevkler"><i class="bi bi-truck"></i> Sevk İşlemleri</a>
                <a class="nav-link" href="/depo/Home/MalKabuller"><i class="bi bi-box-arrow-in-down"></i> Mal Kabul</a>
            }

            <div class="nav-section">Zimmet</div>
            <a class="nav-link" href="/zimmet"><i class="bi bi-person-badge"></i> Zimmet Listesi</a>
            <a class="nav-link" href="/zimmet/Home/Bakim"><i class="bi bi-tools"></i> Bakım & Arıza</a>

            @if (rol != AtomRoller.Tedarikci && rol != AtomRoller.Personel)
            {
                <div class="nav-section">Taşınır İşlemleri</div>
                <a class="nav-link" href="/sayim"><i class="bi bi-clipboard-check"></i> Sayım</a>
                <a class="nav-link" href="/devir"><i class="bi bi-arrow-left-right"></i> Devir</a>
                <a class="nav-link" href="/hurda"><i class="bi bi-trash3"></i> Hurda / Düşüm</a>
            }

            @if (AtomRoller.BakanlikRolleri.Contains(rol) || rol == AtomRoller.IlMuduru)
            {
                <div class="nav-section">Analiz</div>
                <a class="nav-link" href="/raporlama"><i class="bi bi-bar-chart-line"></i> Raporlar & Analiz</a>
            }

            @if (rol == AtomRoller.SistemAdmin || rol == AtomRoller.BakanlikMerkez)
            {
                <div class="nav-section">Yönetim</div>
                <a class="nav-link" href="/yonetim"><i class="bi bi-gear"></i> Sistem Yönetimi</a>
                <a class="nav-link" href="/yonetim/Home/Kullanicilar"><i class="bi bi-people"></i> Kullanıcılar</a>
                <a class="nav-link" href="/yonetim/Home/Kurumlar"><i class="bi bi-bank"></i> Kurumlar</a>
                <a class="nav-link" href="/yonetim/Home/Firmalar"><i class="bi bi-briefcase"></i> Firmalar</a>
                <a class="nav-link" href="/yonetim/Home/TasinirTanimlar"><i class="bi bi-tags"></i> Taşınır Tanımları</a>
                <a class="nav-link" href="/yonetim/Home/AuditLog"><i class="bi bi-journal-text"></i> İşlem Kayıtları</a>
            }
        </div>
    </nav>

    <div id="main-content">
        <div class="topbar">
            <div class="d-flex align-items-center gap-3">
                <button class="btn btn-sm btn-outline-secondary d-md-none" onclick="document.getElementById('sidebar').classList.toggle('show')">
                    <i class="bi bi-list"></i>
                </button>
                @RenderSection("Breadcrumb", required: false)
            </div>
            <div class="d-flex align-items-center gap-2">
                @if (TempData["Basari"] != null)
                {
                    <span class="badge bg-success fs-6 fw-normal"><i class="bi bi-check-circle me-1"></i>@TempData["Basari"]</span>
                }
                @if (TempData["Hata"] != null)
                {
                    <span class="badge bg-danger fs-6 fw-normal"><i class="bi bi-exclamation-triangle me-1"></i>@TempData["Hata"]</span>
                }
                @await Component.InvokeAsync("BildirimCani")
                <span class="text-muted small"><i class="bi bi-person-circle me-1"></i>@kullaniciAdi</span>
                <span class="badge rounded-pill" style="background:var(--atom-secondary);font-size:.7rem;">@rolAdi</span>
                <form method="post" action="/cikis" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Çıkış">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </div>
        <div class="page-content">
            @RenderBody()
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
// Sayfadaki tüm barkod ve QR alanlarını otomatik çiz
function atomKodlariCiz() {
    document.querySelectorAll('svg.atom-barcode:not([data-done])').forEach(function(el){
        try {
            JsBarcode(el, el.getAttribute('data-value') || '', {
                format: 'CODE128',
                height: parseInt(el.getAttribute('data-height') || '38'),
                width: parseFloat(el.getAttribute('data-bw') || '1.6'),
                fontSize: parseInt(el.getAttribute('data-fs') || '12'),
                margin: 4, displayValue: el.getAttribute('data-text') !== 'false'
            });
            el.setAttribute('data-done','1');
        } catch(e) { /* gecersiz deger */ }
    });
    document.querySelectorAll('.atom-qr:not([data-done])').forEach(function(el){
        var v = el.getAttribute('data-value') || '';
        if (!v) return;
        var s = parseInt(el.getAttribute('data-size') || '90');
        new QRCode(el, { text: v, width: s, height: s, correctLevel: QRCode.CorrectLevel.M });
        el.setAttribute('data-done','1');
    });
}
document.addEventListener('DOMContentLoaded', atomKodlariCiz);
</script>
@RenderSection("Scripts", required: false)
</body>
</html>
