@model List<TasinirKayit>
@using ATOM.Models.Domain
@using ATOM.Models.Accounts
@using System.Security.Claims
@{
    ViewData["Title"] = "Taşınır Kayıtları";
    var depolar = ViewBag.Depolar as Dictionary<string, string> ?? new();
    var rol = User.FindFirstValue(ClaimTypes.Role) ?? "";
    var tr = new System.Globalization.CultureInfo("tr-TR");
    var ilListesi = ViewBag.IlListesi as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>();
    int sayfa = ViewBag.Sayfa ?? 1;
    int toplamSayfa = ViewBag.ToplamSayfa ?? 1;
    bool yetkili = new[] { AtomRoller.MerkezDepoSorumlusu, AtomRoller.IlDepoSorumlusu, AtomRoller.SistemAdmin, AtomRoller.BakanlikMerkez }.Contains(rol);
}
@section Breadcrumb {
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/">Panel</a></li>
        <li class="breadcrumb-item active">Taşınır Kayıtları</li>
    </ol>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-upc-scan me-2 text-primary"></i>Taşınır Kayıtları (TKYS)</h5>
    <div class="d-flex gap-2">
        <a href="/kayit/Home/ExcelExport" class="btn btn-outline-success btn-sm"><i class="bi bi-file-earmark-excel me-1"></i>Excel</a>
        <a href="/kayit/Home/WordExport" class="btn btn-outline-primary btn-sm"><i class="bi bi-file-earmark-word me-1"></i>Word</a>
        <a href="/kayit/Home/PdfExport" class="btn btn-outline-danger btn-sm"><i class="bi bi-file-earmark-pdf me-1"></i>PDF</a>
        @if (yetkili)
        {
            <a href="/kayit/Home/Import" class="btn btn-outline-success btn-sm"><i class="bi bi-upload me-1"></i>CSV İçe Aktar</a>
            <a href="/kayit/Home/Duzenle" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni Kayıt</a>
        }
    </div>
</div>

<!-- Özet kartlar -->
<div class="row g-2 mb-3">
    <div class="col-md-4">
        <div class="card stat-card info"><div class="card-body py-2">
            <div class="text-muted small">Toplam Kayıt (filtreli)</div>
            <div class="fs-4 fw-bold">@(((int)(ViewBag.ToplamKayit ?? 0)).ToString("N0"))</div>
        </div></div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card success"><div class="card-body py-2">
            <div class="text-muted small">Toplam Değer</div>
            <div class="fs-4 fw-bold">@(((decimal)(ViewBag.ToplamDeger ?? 0m)).ToString("C0", tr))</div>
        </div></div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card"><div class="card-body py-2">
            <div class="text-muted small">Sayfa</div>
            <div class="fs-4 fw-bold">@sayfa / @Math.Max(1, toplamSayfa)</div>
        </div></div>
    </div>
</div>

<!-- Filtre -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2">
            <div class="col-md-4">
                <input type="text" name="ara" class="form-control form-control-sm" value="@ViewBag.Ara"
                       placeholder="Barkod, sicil, seri, açıklama, TC ara..."/>
            </div>
            <div class="col-md-2">
                <select name="durum" class="form-select form-select-sm">
                    <option value="">– Tüm Durumlar –</option>
                    @foreach (var d in Enum.GetValues<TasinirKayitDurumu>())
                    {
                        if (ViewBag.Durum?.ToString() == d.ToString())
                        { <option value="@d" selected>@d</option> }
                        else
                        { <option value="@d">@d</option> }
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="ilKodu" class="form-select form-select-sm">
                    <option value="">– Tüm İller –</option>
                    @foreach (var il in ilListesi)
                    {
                        if (ViewBag.IlKodu?.ToString() == (string)il.Kod)
                        { <option value="@il.Kod" selected>@il.Ad</option> }
                        else
                        { <option value="@il.Kod">@il.Ad</option> }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-search me-1"></i>Filtrele</button>
            </div>
            <div class="col-md-1">
                <a href="/kayit" class="btn btn-outline-secondary btn-sm w-100">Temizle</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0" style="font-size:.85rem;">
                <thead class="table-light">
                    <tr>
                        <th>Barkod</th>
                        <th>Sicil No</th>
                        <th>Cinsi / Açıklama</th>
                        <th>Marka / Model</th>
                        <th>Seri No</th>
                        <th class="text-end">Birim Fiyat</th>
                        <th>Harcama Birimi</th>
                        <th>İl</th>
                        <th>Durum</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="10" class="text-center text-muted py-4">Kayıt bulunamadı.</td></tr>
                    }
                    @foreach (var k in Model)
                    {
                        <tr>
                            <td>
                                <div class="fw-semibold small">@k.BarKod</div>
                                @if (!string.IsNullOrEmpty(k.BarKod))
                                {
                                    <svg class="atom-barcode" data-value="@k.BarKod" data-height="26" data-bw="1.1" data-fs="0" data-text="false" style="max-width:130px;"></svg>
                                }
                            </td>
                            <td>@k.SicilNo</td>
                            <td data-tanim-id="@k.TasinirTanimId" data-urun-resim="@(k.ResimUrl)" data-urun-ad="@k.Cinsi" data-urun-alt="Sicil: @k.SicilNo">
                                <div>@k.Cinsi @if (!string.IsNullOrEmpty(k.ResimUrl) || !string.IsNullOrEmpty(k.TasinirTanimId)) { <i class="bi bi-image text-muted small" title="Resim için üzerine gelin"></i> }</div>
                                @if (!string.IsNullOrEmpty(k.Aciklama))
                                { <div class="text-muted" style="font-size:.75rem;">@k.Aciklama</div> }
                            </td>
                            <td class="small">@k.MarkaAdi @(string.IsNullOrEmpty(k.Modeli) ? "" : "/ " + k.Modeli)</td>
                            <td class="small text-muted">@k.SeriNo</td>
                            <td class="text-end">@k.BirimFiyat.ToString("C0", tr)</td>
                            <td class="small">@k.HarBirimiAdi</td>
                            <td class="small">@k.IlAdi</td>
                            <td>
                                @{
                                    var (bg, lbl) = k.Durum switch {
                                        TasinirKayitDurumu.Ambarda => ("success","Ambarda"),
                                        TasinirKayitDurumu.Zimmetli => ("primary","Zimmetli"),
                                        TasinirKayitDurumu.Bakimda => ("warning","Bakımda"),
                                        TasinirKayitDurumu.Sevkte => ("info","Sevkte"),
                                        TasinirKayitDurumu.Hurda => ("danger","Hurda"),
                                        TasinirKayitDurumu.Dusum => ("secondary","Düşüm"),
                                        TasinirKayitDurumu.Devir => ("dark","Devir"),
                                        _ => ("secondary", k.Durum.ToString())
                                    };
                                }
                                <span class="badge bg-@bg">@lbl</span>
                            </td>
                            <td><a href="/kayit/Home/Detay/@k.Id" class="btn btn-sm btn-outline-secondary py-0">Detay</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (toplamSayfa > 1)
{
    <nav class="mt-3">
        <ul class="pagination pagination-sm justify-content-center">
            @for (int s = Math.Max(1, sayfa - 3); s <= Math.Min(toplamSayfa, sayfa + 3); s++)
            {
                <li class="page-item @(s == sayfa ? "active" : "")">
                    <a class="page-link" href="?ara=@ViewBag.Ara&durum=@ViewBag.Durum&ilKodu=@ViewBag.IlKodu&sayfa=@s">@s</a>
                </li>
            }
        </ul>
    </nav>
}
