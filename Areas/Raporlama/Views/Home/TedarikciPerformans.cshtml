@model List<ATOM.Areas.Raporlama.Controllers.TedarikciPerformansSatir>
@{
    ViewData["Title"] = "Tedarikçi Performans Raporu";
    var tr = new System.Globalization.CultureInfo("tr-TR");
}
@section Breadcrumb {
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/raporlama">Raporlar</a></li>
        <li class="breadcrumb-item active">Tedarikçi Performansı</li>
    </ol>
}

<h5 class="mb-3 fw-bold"><i class="bi bi-building-check me-2 text-primary"></i>Tedarikçi Performans Raporu</h5>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Firma</th>
                        <th>Vergi No</th>
                        <th class="text-center">Teklif</th>
                        <th class="text-center">Kazanan</th>
                        <th class="text-center">Kazanma Oranı</th>
                        <th class="text-center">Firma Puanı</th>
                        <th class="text-center">Tamamlanan</th>
                        <th class="text-end">Kabul Tutarı</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var x in Model)
                {
                    <tr>
                        <td class="fw-semibold">@x.FirmaAdi</td>
                        <td class="small text-muted">@x.VergiNo</td>
                        <td class="text-center">@x.TeklifSayisi</td>
                        <td class="text-center">@x.KazanilanIhale</td>
                        <td class="text-center">
                            <div class="progress" style="height:6px;">
                                <div class="progress-bar" style="width:@Math.Min(100, x.KazanmaOrani).ToString("N0")%"></div>
                            </div>
                            <span class="small">@x.KazanmaOrani.ToString("N1")%</span>
                        </td>
                        <td class="text-center">@x.PuanOrtalama.ToString("N1")</td>
                        <td class="text-center">@x.TamamlananIhale</td>
                        <td class="text-end">@x.KabulEdilenTeklifTutari.ToString("C2", tr)</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Tedarikçi kaydı yok.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>4734 ve 4735 kapsamındaki teklif, sonuçlandırma ve sözleşme sonrası performans takibi için kontrol raporudur.</p>
