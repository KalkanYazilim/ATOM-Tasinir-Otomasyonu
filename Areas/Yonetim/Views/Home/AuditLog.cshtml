@model List<ATOM.Models.Domain.AuditLog>
@{
    ViewData["Title"] = "İşlem Kayıtları (Audit)";
    var moduller = ViewBag.Moduller as List<string> ?? new();
}
@section Breadcrumb { <ol class="breadcrumb mb-0"><li class="breadcrumb-item active">İşlem Kayıtları</li></ol> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-journal-text me-2 text-primary"></i>İşlem Kayıtları (Audit Log)</h5>
    <form method="get" class="d-flex gap-2">
        <select name="modul" class="form-select form-select-sm" onchange="this.form.submit()">
            <option value="">– Tüm Modüller –</option>
            @foreach (var m in moduller)
            { if (ViewBag.Modul?.ToString() == m) { <option value="@m" selected>@m</option> } else { <option value="@m">@m</option> } }
        </select>
    </form>
</div>

<div class="card"><div class="card-body p-0"><div class="table-responsive">
    <table class="table table-sm table-hover mb-0" style="font-size:.83rem;">
        <thead class="table-light"><tr><th>Tarih</th><th>Kullanıcı</th><th>Rol</th><th>Modül</th><th>İşlem</th><th>Açıklama</th><th>IP</th></tr></thead>
        <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td class="small">@l.Tarih.ToString("dd.MM.yyyy HH:mm:ss")</td>
                <td class="small fw-semibold">@l.KullaniciAdi</td>
                <td class="small text-muted">@l.Rol</td>
                <td><span class="badge bg-light text-dark">@l.Modul</span></td>
                <td class="small">@l.Islem</td>
                <td class="small">@l.Aciklama</td>
                <td class="small text-muted">@l.Ip</td>
            </tr>
        }
        @if (!Model.Any()) { <tr><td colspan="7" class="text-center text-muted py-4">Kayıt yok.</td></tr> }
        </tbody>
    </table>
</div></div></div>
