@model List<ATOM.Models.Accounts.AtomKullanici>
@using ATOM.Models.Accounts
@{
    ViewData["Title"] = "Kullanıcılar";
    var kurumlar = ViewBag.Kurumlar as Dictionary<string, string> ?? new();
}
@section Breadcrumb {
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/yonetim">Yönetim</a></li>
        <li class="breadcrumb-item active">Kullanıcılar</li>
    </ol>
}
<div class="d-flex justify-content-between mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-people me-2 text-primary"></i>Kullanıcılar</h5>
    <a href="/yonetim/Home/KullaniciDuzenle" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr><th>Kullanıcı Adı</th><th>Ad Soyad</th><th>Rol</th><th>Kurum</th><th>Durum</th><th></th></tr>
            </thead>
            <tbody>
                @foreach (var k in Model)
                {
                    <tr>
                        <td class="fw-semibold">@k.KullaniciAdi</td>
                        <td>@k.AdSoyad</td>
                        <td><span class="badge bg-secondary">@AtomRoller.DisplayName(k.Rol)</span></td>
                        <td class="small">@(kurumlar.TryGetValue(k.KurumId, out var km) ? km : k.KurumId)</td>
                        <td><span class="badge bg-@(k.AktifMi?"success":"danger")">@(k.AktifMi?"Aktif":"Pasif")</span></td>
                        <td class="d-flex gap-1">
                            <a href="/yonetim/Home/KullaniciDuzenle/@k.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                            <form method="post" action="/yonetim/Home/KullaniciPasiflestir" onsubmit="return confirm('@(k.AktifMi ? "Pasifleştirilsin mi? (silinmez)" : "Aktifleştirilsin mi?")');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@k.Id"/>
                                <button class="btn btn-sm btn-outline-@(k.AktifMi?"danger":"success")" title="@(k.AktifMi?"Pasifleştir":"Aktifleştir")">
                                    <i class="bi bi-@(k.AktifMi?"pause-circle":"play-circle")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
