@model ATOM.Models.Domain.Firma
@{ ViewData["Title"] = string.IsNullOrEmpty(Model.Id) ? "Yeni Firma" : "Firma Düzenle"; }
@section Breadcrumb { <ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a href="/yonetim/Home/Firmalar">Firmalar</a></li><li class="breadcrumb-item active">@ViewData["Title"]</li></ol> }

<form method="post" action="/yonetim/Home/FirmaDuzenle">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id"/>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-briefcase me-2 text-primary"></i>@ViewData["Title"]</h5>
        <div><a href="/yonetim/Home/Firmalar" class="btn btn-outline-secondary btn-sm">İptal</a>
            <button class="btn btn-primary btn-sm"><i class="bi bi-save me-1"></i>Kaydet</button></div>
    </div>
    <div class="card"><div class="card-body"><div class="row g-3">
        <div class="col-md-6"><label class="form-label small fw-semibold">Firma Adı <span class="text-danger">*</span></label><input name="Ad" value="@Model.Ad" class="form-control form-control-sm" required/></div>
        <div class="col-md-3"><label class="form-label small fw-semibold">Vergi No</label><input name="VergiNo" value="@Model.VergiNo" class="form-control form-control-sm"/></div>
        <div class="col-md-3"><label class="form-label small fw-semibold">Vergi Dairesi</label><input name="VergiDairesi" value="@Model.VergiDairesi" class="form-control form-control-sm"/></div>
        <div class="col-md-6"><label class="form-label small fw-semibold">Yetkili Kişi</label><input name="YetkiliKisi" value="@Model.YetkiliKisi" class="form-control form-control-sm"/></div>
        <div class="col-md-3"><label class="form-label small fw-semibold">Telefon</label><input name="Telefon" value="@Model.Telefon" class="form-control form-control-sm"/></div>
        <div class="col-md-3"><label class="form-label small fw-semibold">E-posta</label><input name="Email" value="@Model.Email" class="form-control form-control-sm"/></div>
        <div class="col-12"><label class="form-label small fw-semibold">Adres</label><input name="Adres" value="@Model.Adres" class="form-control form-control-sm"/></div>
        <div class="col-12"><div class="form-check"><input type="checkbox" name="AktifMi" value="true" class="form-check-input" id="aktif" @(Model.AktifMi || string.IsNullOrEmpty(Model.Id) ? "checked" : "")/><label class="form-check-label" for="aktif">Aktif</label></div></div>
    </div></div></div>
</form>
