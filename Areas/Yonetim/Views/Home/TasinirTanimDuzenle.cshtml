@model ATOM.Models.Domain.TasinirTanim
@using ATOM.Models.Domain
@{ ViewData["Title"] = string.IsNullOrEmpty(Model.Id) ? "Yeni Taşınır Tanımı" : "Taşınır Tanımı Düzenle"; }
@section Breadcrumb { <ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a href="/yonetim/Home/TasinirTanimlar">Taşınır Tanımları</a></li><li class="breadcrumb-item active">@ViewData["Title"]</li></ol> }

<form method="post" action="/yonetim/Home/TasinirTanimDuzenle" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Id" value="@Model.Id"/>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-tags me-2 text-primary"></i>@ViewData["Title"]</h5>
        <div><a href="/yonetim/Home/TasinirTanimlar" class="btn btn-outline-secondary btn-sm">İptal</a>
            <button class="btn btn-primary btn-sm"><i class="bi bi-save me-1"></i>Kaydet</button></div>
    </div>
    <div class="card"><div class="card-body"><div class="row g-3">
        <div class="col-md-3"><label class="form-label small fw-semibold">Hesap Kodu</label><input name="Kod" value="@Model.Kod" class="form-control form-control-sm" placeholder="795.05.01.01"/></div>
        <div class="col-md-6"><label class="form-label small fw-semibold">Ad <span class="text-danger">*</span></label><input name="Ad" value="@Model.Ad" class="form-control form-control-sm" required/></div>
        <div class="col-md-3">
            <label class="form-label small fw-semibold">Kategori</label>
            <select name="Kategori" class="form-select form-select-sm">
                @foreach (var c in Enum.GetValues<TasinirKategori>())
                { if (Model.Kategori == c) { <option value="@c" selected>@c</option> } else { <option value="@c">@c</option> } }
            </select>
        </div>
        <div class="col-md-3"><label class="form-label small fw-semibold">Ölçü Birimi</label><input name="Birim" value="@(string.IsNullOrEmpty(Model.Birim)?"Adet":Model.Birim)" class="form-control form-control-sm"/></div>
        <div class="col-md-3"><label class="form-label small fw-semibold">Kritik Eşik</label><input name="KritikEsik" type="number" value="@Model.KritikEsik" class="form-control form-control-sm"/></div>
        <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input type="checkbox" name="DemirbasMi" value="true" class="form-check-input" id="demirbas" @(Model.DemirbasMi ? "checked" : "")/><label class="form-check-label small" for="demirbas">Demirbaş (tekil sicil/barkod)</label></div></div>
        <div class="col-md-3 d-flex align-items-end"><div class="form-check"><input type="checkbox" name="AktifMi" value="true" class="form-check-input" id="aktif" @(Model.AktifMi || string.IsNullOrEmpty(Model.Id) ? "checked" : "")/><label class="form-check-label" for="aktif">Aktif</label></div></div>
        <div class="col-12"><label class="form-label small fw-semibold">Açıklama</label><textarea name="Aciklama" class="form-control form-control-sm" rows="2">@Model.Aciklama</textarea></div>
        <div class="col-md-6">
            <label class="form-label small fw-semibold">Ürün Görseli</label>
            <input type="file" name="resim" accept="image/*" class="form-control form-control-sm"/>
        </div>
        @if (!string.IsNullOrEmpty(Model.ResimUrl))
        {
            <div class="col-md-6"><label class="form-label small fw-semibold">Mevcut Görsel</label><br/>
                <img src="@Model.ResimUrl" class="img-thumbnail" style="max-height:90px;"/></div>
        }
    </div></div></div>
</form>
