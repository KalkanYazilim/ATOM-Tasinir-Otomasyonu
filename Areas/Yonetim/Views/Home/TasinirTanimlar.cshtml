@model List<ATOM.Models.Domain.TasinirTanim>
@using ATOM.Models.Domain
@{
    ViewData["Title"] = "Taşınır Tanımları";
}
@section Breadcrumb {
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/yonetim">Yönetim</a></li>
        <li class="breadcrumb-item active">Taşınır Tanımları</li>
    </ol>
}
<div class="d-flex justify-content-between mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-tags me-2 text-primary"></i>Taşınır Tanımları</h5>
    <a href="/yonetim/Home/TasinirTanimDuzenle" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Yeni</a>
</div>
<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr><th style="width:48px"></th><th>Kod</th><th>Ad</th><th>Kategori</th><th>Birim</th><th>Tür</th><th>Durum</th><th></th></tr>
                </thead>
                <tbody>
                    @foreach (var t in Model.OrderBy(x => x.Kod))
                    {
                        <tr data-tanim-id="@t.Id" data-urun-resim="@t.ResimUrl" data-urun-ad="@t.Ad" data-urun-alt="@t.Kod">
                            <td>
                                @if (!string.IsNullOrEmpty(t.ResimUrl))
                                { <img src="@t.ResimUrl" class="rounded" style="width:38px;height:38px;object-fit:cover;"/> }
                                else { <span class="text-muted"><i class="bi bi-image"></i></span> }
                            </td>
                            <td class="fw-semibold text-muted small">@t.Kod</td>
                            <td>@t.Ad</td>
                            <td><span class="badge bg-info text-dark">@TasinirKategoriHelper.DisplayName(t.Kategori)</span></td>
                            <td>@t.Birim</td>
                            <td>@(t.DemirbasMi ? "<span class='badge bg-secondary'>Demirbaş</span>" : "<span class='badge bg-light text-dark'>Sarf</span>")</td>
                            <td><span class="badge bg-@(t.AktifMi?"success":"danger")">@(t.AktifMi?"Aktif":"Pasif")</span></td>
                            <td><a href="/yonetim/Home/TasinirTanimDuzenle/@t.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
