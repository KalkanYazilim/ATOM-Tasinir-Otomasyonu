@model object
@using ATOM.Models.Domain
@{
    ViewData["Title"] = "Yeni Sayım";
    var depolar = ViewBag.Depolar as List<Depo> ?? new();
}
@section Breadcrumb { <ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a href="/sayim">Sayım</a></li><li class="breadcrumb-item active">Yeni</li></ol> }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-clipboard-check me-2 text-primary"></i>Yeni Sayım Başlat</h5>
</div>

<div class="card"><div class="card-body">
    <form method="post" action="/sayim/Home/Yeni">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label small fw-semibold">Depo <span class="text-danger">*</span></label>
                <select name="depoId" class="form-select form-select-sm" required>
                    <option value="">– Seçiniz –</option>
                    @foreach (var d in depolar) { <option value="@d.Id">@d.Ad (@d.Stoklar.Count kalem)</option> }
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label small fw-semibold">Sayım Başlığı</label>
                <input name="baslik" class="form-control form-control-sm" placeholder="Örn: 2026 Yılı Yıl Sonu Sayımı"/>
            </div>
        </div>
        <p class="text-muted small mt-3"><i class="bi bi-info-circle me-1"></i>Sayım başlatıldığında deponun mevcut kaydi stoğu otomatik yüklenir. Fiili miktarları sonra girersiniz.</p>
        <div class="mt-2">
            <a href="/sayim" class="btn btn-outline-secondary btn-sm">İptal</a>
            <button class="btn btn-primary btn-sm"><i class="bi bi-play-circle me-1"></i>Sayımı Başlat</button>
        </div>
    </form>
</div></div>
