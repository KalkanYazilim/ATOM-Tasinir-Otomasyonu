@model ATOM.Models.Domain.HurdaKaydi
@using ATOM.Models.Domain
@using ATOM.Models.Accounts
@using System.Security.Claims
@{
    ViewData["Title"] = $"Hurda – {Model.HurdaNo}";
    var tanimlar = ViewBag.Tanimlar as Dictionary<string, string> ?? new();
    var rol = User.FindFirstValue(ClaimTypes.Role) ?? "";
    bool komisyon = new[]{AtomRoller.IlMuduru,AtomRoller.MerkezDepoSorumlusu,AtomRoller.BakanlikMerkez,AtomRoller.SistemAdmin}.Contains(rol);
    bool ustOnay = new[]{AtomRoller.BakanlikMerkez,AtomRoller.SistemAdmin}.Contains(rol);
}
@section Breadcrumb {
    <ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a href="/hurda">Hurda</a></li><li class="breadcrumb-item active">@Model.HurdaNo</li></ol>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-trash3 me-2 text-primary"></i>@Model.HurdaNo
        <span class="badge bg-secondary ms-1">@Model.DusumTuru</span></h5>
    <div class="d-flex gap-2">
        @if (komisyon && Model.Durum == HurdaDurumu.Talep)
        { <button class="btn btn-info btn-sm" data-bs-toggle="modal" data-bs-target="#komisyonModal">Komisyon Kararı</button> }
        @if (ustOnay && Model.Durum == HurdaDurumu.Komisyon)
        { <button class="btn btn-success btn-sm" data-bs-toggle="modal" data-bs-target="#onayModal">Üst Onay</button> }
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card mb-3"><div class="card-body"><div class="row g-3">
            <div class="col-md-4"><label class="text-muted small">Tür</label><div class="fw-semibold">@Model.DusumTuru</div></div>
            <div class="col-md-4"><label class="text-muted small">Durum</label><div>@Model.Durum</div></div>
            <div class="col-md-4"><label class="text-muted small">TİF No</label><div>@(string.IsNullOrEmpty(Model.TifNo)?"–":Model.TifNo)</div></div>
            <div class="col-12"><label class="text-muted small">Gerekçe</label><div class="p-2 bg-light rounded">@Model.Gerekce</div></div>
            @if (!string.IsNullOrEmpty(Model.KomisyonKarari))
            { <div class="col-12"><label class="text-muted small">Komisyon Kararı</label><div class="p-2 bg-light rounded">@Model.KomisyonKarari</div></div> }
        </div></div></div>

        <div class="card"><div class="card-header bg-white fw-semibold">Kalemler (@Model.Kalemler.Count)</div>
            <div class="card-body p-0"><div class="table-responsive">
                <table class="table table-sm mb-0"><thead class="table-light"><tr><th>Taşınır</th><th>Seri</th><th class="text-center">Miktar</th><th>Açıklama</th></tr></thead>
                    <tbody>
                    @foreach (var k in Model.Kalemler)
                    {
                        <tr><td>@(tanimlar.TryGetValue(k.TasinirTanimId, out var t) ? t : k.TasinirTanimId)</td>
                            <td class="small text-muted">@k.SeriNo</td><td class="text-center">@k.Miktar</td><td class="small">@k.DurumAciklama</td></tr>
                    }
                    </tbody>
                </table>
            </div></div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card"><div class="card-header bg-white fw-semibold"><i class="bi bi-clock-history me-2"></i>Onay Geçmişi</div>
            <div class="card-body p-0">
                @if (Model.OnayGecmisi.Any())
                {
                    <div class="list-group list-group-flush">
                    @foreach (var o in Model.OnayGecmisi.OrderByDescending(x => x.Tarih))
                    {
                        <div class="list-group-item py-2">
                            <div class="d-flex justify-content-between"><span class="fw-semibold small">@o.Asama</span>
                                <span class="badge bg-@(o.Karar==OnayDurumu.Onaylandi?"success":"danger")">@o.Karar</span></div>
                            @if (!string.IsNullOrEmpty(o.Aciklama)) { <div class="text-muted small">@o.Aciklama</div> }
                            <div class="text-muted" style="font-size:.72rem;">@o.KullaniciAdi · @o.Tarih.ToString("dd.MM.yyyy HH:mm")</div>
                        </div>
                    }
                    </div>
                }
                else { <div class="text-muted text-center py-3 small">Henüz işlem yok.</div> }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="komisyonModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <form method="post" action="/hurda/Home/KomisyonKarar">
        @Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"/>
        <div class="modal-header"><h6 class="modal-title">Komisyon Kararı</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body"><textarea name="komisyonKarari" class="form-control form-control-sm" rows="3" placeholder="Komisyon kararı" required></textarea>
            <input type="hidden" name="karar" value="onay"/></div>
        <div class="modal-footer"><button class="btn btn-info btn-sm">Kaydet</button></div>
    </form>
</div></div></div>

<div class="modal fade" id="onayModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content">
    <form method="post" action="/hurda/Home/Onayla">
        @Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.Id"/>
        <div class="modal-header"><h6 class="modal-title">Üst Onay</h6><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
        <div class="modal-body"><p class="small text-muted">Onaylanınca stok ve tekil kayıtlardan düşülür.</p>
            <textarea name="aciklama" class="form-control form-control-sm" rows="2" placeholder="Açıklama" required></textarea></div>
        <div class="modal-footer">
            <button type="submit" name="onayla" value="false" class="btn btn-outline-danger btn-sm">Reddet</button>
            <button type="submit" name="onayla" value="true" class="btn btn-success btn-sm">Onayla ve Düş</button>
        </div>
    </form>
</div></div></div>
