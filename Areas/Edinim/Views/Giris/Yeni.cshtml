@model ATOM.Models.Domain.MalGirisBelgesi
@using ATOM.Models.Domain
@{
    ViewData["Title"] = "Yeni Mal Girişi";
    var depolar = ViewBag.Depolar as List<Depo> ?? new();
    var tanimlar = ViewBag.Tanimlar as List<TasinirTanim> ?? new();
    var firmalar = ViewBag.Firmalar as List<Firma> ?? new();
    var ihaleler = ViewBag.Ihaleler as List<Ihale> ?? new();
    var yontem = (GirisYontemi)(ViewBag.SecilenYontem ?? GirisYontemi.KurumButcesiAlim);
    bool satinAlma = yontem is GirisYontemi.SatinAlmaIhale or GirisYontemi.SatinAlmaDogrudanTemin or GirisYontemi.KurumButcesiAlim;
}
@section Breadcrumb { <ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a href="/edinim/Giris">Mal Girişi</a></li><li class="breadcrumb-item active">Yeni</li></ol> }

<form method="post" action="/edinim/Giris/Yeni">
    @Html.AntiForgeryToken()
    <input type="hidden" name="Yontem" value="@yontem"/>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-box-arrow-in-down me-2 text-primary"></i>@GirisCikisYardimci.GirisAd(yontem)</h5>
        <div><a href="/edinim/Giris" class="btn btn-outline-secondary btn-sm">İptal</a>
            <button class="btn btn-primary btn-sm"><i class="bi bi-save me-1"></i>Girişi Kaydet</button></div>
    </div>

    <div class="alert alert-light border small mb-3"><i class="bi bi-bank me-1 text-primary"></i>
        <strong>Mevzuat Dayanağı:</strong> @GirisCikisYardimci.GirisDayanak(yontem)
    </div>

    <div class="card mb-3"><div class="card-header bg-white fw-semibold">Genel Bilgiler</div><div class="card-body"><div class="row g-3">
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Yöntem</label>
            <select class="form-select form-select-sm" onchange="location.href='/edinim/Giris/Yeni?yontem='+this.value">
                @foreach (var y in Enum.GetValues<GirisYontemi>())
                { if (y == yontem) { <option value="@y" selected>@GirisCikisYardimci.GirisAd(y)</option> } else { <option value="@y">@GirisCikisYardimci.GirisAd(y)</option> } }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Depo (giriş yapılacak) <span class="text-danger">*</span></label>
            <select name="DepoId" class="form-select form-select-sm" required>
                <option value="">– Seçiniz –</option>
                @foreach (var d in depolar) { <option value="@d.Id">@d.Ad</option> }
            </select>
        </div>
        <div class="col-md-4"><label class="form-label small fw-semibold">Dayanak Belge (karar/protokol/yazı no)</label><input name="DayanakBelge" class="form-control form-control-sm"/></div>

        @if (yontem == GirisYontemi.SatinAlmaIhale)
        {
            <div class="col-md-6"><label class="form-label small fw-semibold">İlgili İhale</label>
                <select name="IhaleId" class="form-select form-select-sm">
                    <option value="">– Seçiniz –</option>
                    @foreach (var i in ihaleler) { <option value="@i.Id">@i.IhaleNo – @i.Baslik</option> }
                </select></div>
        }
        @if (satinAlma)
        {
            <div class="col-md-6"><label class="form-label small fw-semibold">Firma</label>
                <select name="FirmaId" class="form-select form-select-sm">
                    <option value="">– Seçiniz –</option>
                    @foreach (var f in firmalar) { <option value="@f.Id">@f.Ad</option> }
                </select></div>
            <div class="col-md-3"><label class="form-label small fw-semibold">Fatura No</label><input name="FaturaNo" class="form-control form-control-sm"/></div>
            <div class="col-md-3"><label class="form-label small fw-semibold">Fatura Tutarı (₺)</label><input name="FaturaTutari" type="number" step="0.01" value="0" class="form-control form-control-sm"/></div>
            <div class="col-md-3"><label class="form-label small fw-semibold">İrsaliye No</label><input name="IrsaliyeNo" class="form-control form-control-sm"/></div>
            <div class="col-md-3"><label class="form-label small fw-semibold">Bütçe Tertibi</label><input name="ButceTertibi" class="form-control form-control-sm" placeholder="03.7.1.01"/></div>
        }
        @if (yontem == GirisYontemi.BagisYardim)
        {
            <div class="col-md-6"><label class="form-label small fw-semibold">Bağış/Yardım Yapan</label><input name="BagisYapan" class="form-control form-control-sm" placeholder="Kişi/Kurum adı"/></div>
        }
        <div class="col-12"><label class="form-label small fw-semibold">Açıklama</label><input name="Aciklama" class="form-control form-control-sm"/></div>
    </div></div></div>

    <div class="card"><div class="card-header bg-white fw-semibold d-flex justify-content-between">
        <span><i class="bi bi-list-ul me-2"></i>Giriş Kalemleri</span>
        <button type="button" class="btn btn-outline-primary btn-sm py-0" onclick="kalemEkle()"><i class="bi bi-plus"></i> Kalem Ekle</button>
    </div>
    <div class="card-body p-0"><div class="table-responsive">
        <table class="table table-sm mb-0 align-middle"><thead class="table-light">
            <tr><th style="min-width:200px">Taşınır</th><th>Miktar</th><th>Birim Fiyat</th><th>Marka</th><th>Model</th><th>Tür</th><th></th></tr>
        </thead><tbody id="kalemBody"></tbody></table>
    </div></div></div>
    <p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>Kaydedildiğinde stok artar; demirbaş kalemler için otomatik tekil taşınır (sicil/barkod) kaydı ve TİF üretilir.</p>
</form>

@section Scripts {
<script>
const opts = `@Html.Raw(string.Join("", tanimlar.Select(t => $"<option value='{t.Id}' data-demirbas='{(t.DemirbasMi ? "1" : "0")}'>{System.Net.WebUtility.HtmlEncode(t.Ad)}</option>")))`;
function kalemEkle() {
    const tr = document.createElement('tr');
    tr.innerHTML = `
        <td><select name="tasinirIds" class="form-select form-select-sm">${opts}</select></td>
        <td><input name="miktarlar" type="number" value="1" min="1" class="form-control form-control-sm" style="width:75px"/></td>
        <td><input name="birimFiyatlar" type="number" step="0.01" value="0" class="form-control form-control-sm" style="width:95px"/></td>
        <td><input name="markalar" class="form-control form-control-sm" style="width:90px"/></td>
        <td><input name="modeller" class="form-control form-control-sm" style="width:90px"/></td>
        <td class="tur-hucre text-center"><span class="badge bg-light text-dark">—</span></td>
        <td><button type="button" class="btn btn-sm btn-outline-danger py-0" onclick="this.closest('tr').remove()">×</button></td>`;
    document.getElementById('kalemBody').appendChild(tr);
    const sel = tr.querySelector('select[name="tasinirIds"]');
    sel.addEventListener('change', () => turGuncelle(sel));
    turGuncelle(sel);
}
function turGuncelle(sel) {
    const dem = sel.options[sel.selectedIndex]?.getAttribute('data-demirbas') === '1';
    const h = sel.closest('tr').querySelector('.tur-hucre');
    h.innerHTML = dem ? '<span class="badge bg-warning text-dark">Demirbaş</span>' : '<span class="badge bg-info">Sarf</span>';
}
kalemEkle();
</script>
}
