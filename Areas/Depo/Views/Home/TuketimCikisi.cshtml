@using ATOM.Models.Domain
@{
    ViewData["Title"] = "Tüketim Malzemesi Çıkışı";
    var depolar = ViewBag.Depolar as List<Depo> ?? new();
    var sarf = ViewBag.SarfTanimlar as List<TasinirTanim> ?? new();
    var personeller = ViewBag.Personeller as List<ATOM.Models.Accounts.AtomKullanici> ?? new();
}
@section Breadcrumb { <ol class="breadcrumb mb-0"><li class="breadcrumb-item"><a href="/depo">Depo</a></li><li class="breadcrumb-item active">Tüketim Çıkışı</li></ol> }

<h5 class="mb-3 fw-bold"><i class="bi bi-box-arrow-up me-2 text-primary"></i>Tüketim Malzemesi Çıkışı <span class="text-muted fw-normal small">(sarf — Taşınır İstek/Çıkış)</span></h5>

<div class="card"><div class="card-body">
    <form method="post" action="/depo/Home/TuketimCikisi">
        @Html.AntiForgeryToken()
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Depo <span class="text-danger">*</span></label>
                <select name="depoId" class="form-select form-select-sm" required>
                    <option value="">– Seçiniz –</option>
                    @foreach (var d in depolar) { <option value="@d.Id">@d.Ad</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Sarf Malzeme <span class="text-danger">*</span></label>
                <select name="tanimId" class="form-select form-select-sm" required>
                    <option value="">– Seçiniz –</option>
                    @foreach (var t in sarf) { <option value="@t.Id">@t.Ad (@t.Birim)</option> }
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label small fw-semibold">Miktar <span class="text-danger">*</span></label>
                <input name="miktar" type="number" min="1" value="1" class="form-control form-control-sm" required/>
            </div>
            <div class="col-md-6">
                <label class="form-label small fw-semibold">Talep Eden Birim</label>
                <input name="birim" class="form-control form-control-sm" placeholder="Örn: İdari ve Mali İşler Şube Md."/>
            </div>
            <div class="col-md-6">
                <label class="form-label small fw-semibold">Personel <span class="text-muted fw-normal">(opsiyonel)</span></label>
                <select name="personelId" class="form-select form-select-sm">
                    <option value="">– Birim tüketimi olarak düş –</option>
                    @foreach (var p in personeller) { <option value="@p.Id">@p.AdSoyad</option> }
                </select>
            </div>
            <div class="col-md-12">
                <label class="form-label small fw-semibold">Kullanım Yeri / Amaç</label>
                <input name="kullanimYeri" class="form-control form-control-sm"/>
            </div>
        </div>
        <p class="text-muted small mt-3"><i class="bi bi-info-circle me-1"></i>Sarf malzeme demirbaş gibi zimmetlenmez; seçilen personel veya birim adına belgeli tüketim çıkışıyla stoktan düşülür.</p>
        <button class="btn btn-primary btn-sm"><i class="bi bi-box-arrow-up me-1"></i>Çıkış Yap</button>
    </form>
</div></div>
