@model ATOM.Models.Domain.Sevk
@using ATOM.Models.Domain
@{
    ViewData["Title"] = "Yeni Sevk";
    var depolar = ViewBag.Depolar as List<Depo> ?? new();
    var kurumlar = ViewBag.Kurumlar as Dictionary<string, string> ?? new();
    var tanimlar = ViewBag.Tanimlar as Dictionary<string, string> ?? new();
}
@section Breadcrumb {
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/depo/Home/Sevkler">Sevk</a></li>
        <li class="breadcrumb-item active">Yeni</li>
    </ol>
}

<form method="post" action="/depo/Home/YeniSevk">
    @Html.AntiForgeryToken()
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-truck me-2 text-primary"></i>Yeni Sevk</h5>
        <div><a href="/depo/Home/Sevkler" class="btn btn-outline-secondary btn-sm">İptal</a>
            <button class="btn btn-primary btn-sm"><i class="bi bi-save me-1"></i>Sevk Oluştur</button></div>
    </div>

    <div class="card mb-3"><div class="card-body"><div class="row g-3">
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Kaynak Depo <span class="text-danger">*</span></label>
            <select name="KaynakDepoId" class="form-select form-select-sm" required>
                <option value="">– Seçiniz –</option>
                @foreach (var d in depolar) { <option value="@d.Id">@d.Ad</option> }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Hedef Depo</label>
            <select name="HedefDepoId" class="form-select form-select-sm">
                <option value="">– Seçiniz –</option>
                @foreach (var d in depolar) { <option value="@d.Id">@d.Ad</option> }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label small fw-semibold">Hedef Kurum</label>
            <select name="HedefKurumId" class="form-select form-select-sm">
                <option value="">– Seçiniz –</option>
                @foreach (var k in kurumlar) { <option value="@k.Key">@k.Value</option> }
            </select>
        </div>
        <div class="col-md-3"><label class="form-label small fw-semibold">Taşıyıcı</label><input name="TasimaciAdi" class="form-control form-control-sm"/></div>
        <div class="col-md-3"><label class="form-label small fw-semibold">Telefon</label><input name="TasimaciTelefon" class="form-control form-control-sm"/></div>
        <div class="col-md-3"><label class="form-label small fw-semibold">Araç Plaka</label><input name="AracPlaka" class="form-control form-control-sm"/></div>
        <div class="col-md-3"><label class="form-label small fw-semibold">İrsaliye No</label><input name="IrsaliyeNo" class="form-control form-control-sm"/></div>
        <div class="col-12"><label class="form-label small fw-semibold">Açıklama</label><input name="Aciklama" class="form-control form-control-sm"/></div>
    </div></div></div>

    <div class="card"><div class="card-header bg-white fw-semibold d-flex justify-content-between">
        <span><i class="bi bi-list-ul me-2"></i>Sevk Kalemleri</span>
        <button type="button" class="btn btn-outline-primary btn-sm py-0" onclick="kalemEkle()"><i class="bi bi-plus"></i> Kalem Ekle</button>
    </div>
    <div class="card-body p-0"><div class="table-responsive">
        <table class="table table-sm mb-0 align-middle">
            <thead class="table-light"><tr><th style="min-width:240px">Taşınır</th><th>Miktar</th><th></th></tr></thead>
            <tbody id="kalemBody"></tbody>
        </table>
    </div></div></div>
    <p class="text-muted small mt-2"><i class="bi bi-info-circle me-1"></i>Sevk oluşturulduğunda kaynak depo stoğu otomatik düşülür. Yetersiz stokta işlem engellenir.</p>
</form>

@section Scripts {
<script>
const tanimOpts = `@Html.Raw(string.Join("", tanimlar.Select(t => $"<option value='{t.Key}'>{System.Net.WebUtility.HtmlEncode(t.Value)}</option>")))`;
function kalemEkle() {
    const tr = document.createElement('tr');
    tr.innerHTML = `
        <td><select name="tasinirIds" class="form-select form-select-sm">${tanimOpts}</select></td>
        <td><input name="miktarlar" type="number" value="1" min="1" class="form-control form-control-sm" style="width:90px"/></td>
        <td><button type="button" class="btn btn-sm btn-outline-danger py-0" onclick="this.closest('tr').remove()">×</button></td>`;
    document.getElementById('kalemBody').appendChild(tr);
}
kalemEkle();
</script>
}
