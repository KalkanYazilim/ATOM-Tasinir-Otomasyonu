@model List<ATOM.Models.Domain.StokHareket>
@using ATOM.Models.Domain
@{
    var depo = ViewBag.Depo as Depo;
    var tanim = ViewBag.Tanim as TasinirTanim;
    ViewData["Title"] = $"Stok Kartı – {tanim?.Ad}";
    var tr = new System.Globalization.CultureInfo("tr-TR");
}
@section Breadcrumb {
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/depo">Depolar</a></li>
        <li class="breadcrumb-item"><a href="/depo/Home/Detay/@depo?.Id">@depo?.Ad</a></li>
        <li class="breadcrumb-item active">Stok Kartı</li>
    </ol>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-card-list me-2 text-primary"></i>@tanim?.Ad
        <span class="text-muted fw-normal fs-6">· @depo?.Ad</span></h5>
    <span class="badge bg-primary fs-6">Mevcut: @ViewBag.MevcutStok @(tanim?.Birim)</span>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Tarih</th><th>İşlem</th><th>Belge</th>
                        <th class="text-end text-success">Giriş</th><th class="text-end text-danger">Çıkış</th>
                        <th class="text-end">Kalan</th><th>Kullanıcı</th><th>Açıklama</th></tr>
                </thead>
                <tbody>
                @foreach (var h in Model)
                {
                    <tr>
                        <td class="small">@h.Tarih.ToString("dd.MM.yyyy HH:mm")</td>
                        <td><span class="badge bg-light text-dark">@StokHareket.IslemAdi(h.IslemTuru)</span></td>
                        <td class="small text-muted">@h.KaynakBelgeNo</td>
                        <td class="text-end text-success fw-semibold">@(h.GirisMiktar > 0 ? "+" + h.GirisMiktar : "")</td>
                        <td class="text-end text-danger fw-semibold">@(h.CikisMiktar > 0 ? "-" + h.CikisMiktar : "")</td>
                        <td class="text-end fw-bold">@h.KalanMiktar</td>
                        <td class="small">@h.KullaniciAdi</td>
                        <td class="small text-muted">@h.Aciklama</td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Bu kalem için hareket kaydı yok.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
