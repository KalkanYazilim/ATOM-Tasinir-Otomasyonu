@model List<IhtiyacTalebi>
@using ATOM.Models.Domain
@{
    ViewData["Title"] = "İhtiyaç Talepleri";
    var kurumlar = ViewBag.Kurumlar as Dictionary<string, string> ?? new();
}
@section Breadcrumb {
    <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/">Panel</a></li>
        <li class="breadcrumb-item active">İhtiyaç Talepleri</li>
    </ol>
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 fw-bold"><i class="bi bi-clipboard2-plus me-2 text-primary"></i>İhtiyaç Talepleri</h5>
    <a href="/talep/Home/Yeni" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Yeni Talep
    </a>
</div>

<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2">
            <div class="col-md-6">
                <input type="text" name="ara" class="form-control form-control-sm" placeholder="Talep No veya açıklama ara..." value="@ViewBag.Ara"/>
            </div>
            <div class="col-md-4">
                <select name="durum" class="form-select form-select-sm">
                    <option value="">– Tüm Durumlar –</option>
                    @foreach (var d in Enum.GetValues<TalepDurumu>())
                    {
                        @if (ViewBag.Durum?.ToString() == d.ToString())
                        {
                            <option value="@d" selected>@d</option>
                        }
                        else
                        {
                            <option value="@d">@d</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <button class="btn btn-outline-primary btn-sm w-100">Filtrele</button>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Talep No</th>
                        <th>Kurum</th>
                        <th class="text-center">Kalem</th>
                        <th>Öncelik</th>
                        <th>Durum</th>
                        <th>Tarih</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr><td colspan="7" class="text-center text-muted py-4">Kayıt bulunamadı.</td></tr>
                    }
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@t.TalepNo</td>
                            <td>@(kurumlar.TryGetValue(t.TalepciKurumId, out var k) ? k : t.TalepciKurumId)</td>
                            <td class="text-center">@t.Kalemler.Count</td>
                            <td>
                                @{
                                    var oncelikBg = t.OncelikSeviyesi switch {
                                        "Acil" => "danger", "Yüksek" => "warning", "Normal" => "secondary", _ => "light text-dark"
                                    };
                                }
                                <span class="badge bg-@oncelikBg">@t.OncelikSeviyesi</span>
                            </td>
                            <td>
                                @{
                                    var (bg, lbl) = t.Durum switch {
                                        TalepDurumu.Taslak => ("secondary","Taslak"),
                                        TalepDurumu.GonderildiIlOnay => ("warning","İl Onayı Bekleniyor"),
                                        TalepDurumu.IlOnaylandi => ("info","İl Onayladı"),
                                        TalepDurumu.BakanlikAlindi => ("primary","Bakanlıkta"),
                                        TalepDurumu.BakanlikInceliyor => ("primary","İncelemede"),
                                        TalepDurumu.KarsilandiKismi => ("success","Kısmen Karşılandı"),
                                        TalepDurumu.KarsilandiTamamen => ("success","Karşılandı"),
                                        TalepDurumu.Reddedildi => ("danger","Reddedildi"),
                                        _ => ("secondary",t.Durum.ToString())
                                    };
                                }
                                <span class="badge bg-@bg">@lbl</span>
                            </td>
                            <td class="text-muted small">@t.TalepTarihi.ToString("dd.MM.yyyy")</td>
                            <td><a href="/talep/Home/Detay/@t.Id" class="btn btn-sm btn-outline-secondary">Detay</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
